---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}

const { title, description, ogImage = '/images/og-default.jpg', canonical } = Astro.props;
const siteUrl = 'https://ernst-haus-garten.de';
const canonicalUrl = canonical ? `${siteUrl}${canonical}` : new URL(Astro.url.pathname, siteUrl).toString();
---

<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>

  <link rel="canonical" href={canonicalUrl} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:locale" content="de_DE" />
  <meta property="og:site_name" content="ERNST HAUS & GARTEN" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <!-- Schema.org LocalBusiness -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "ERNST HAUS & GARTEN",
    "description": "Gartenpflege, Baumpflege und Entrümpelung in Marienheide und Umgebung.",
    "url": siteUrl,
    "telephone": "+49 XXXX XXXXXXX",
    "email": "info@ernst-haus-garten.de",
    "areaServed": [
      { "@type": "City", "name": "Marienheide" },
      { "@type": "City", "name": "Gummersbach" },
      { "@type": "City", "name": "Wipperfürth" },
      { "@type": "City", "name": "Bergneustadt" },
      { "@type": "City", "name": "Meinerzhagen" },
      { "@type": "City", "name": "Wiehl" },
      { "@type": "City", "name": "Engelskirchen" }
    ],
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Marienheide",
      "addressRegion": "Nordrhein-Westfalen",
      "addressCountry": "DE"
    },
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Dienstleistungen",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Gartenpflege & Heckenschnitt" }},
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Baumpflege & Fällarbeiten" }},
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Entrümpelung & Haushaltsauflösung" }},
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Winterdienst & kleinere Außenarbeiten" }}
      ]
    }
  })} />
</head>
<body class="min-h-screen flex flex-col bg-warm-white text-warm-gray-800">
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
