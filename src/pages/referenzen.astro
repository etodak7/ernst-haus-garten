---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import BeforeAfterSlider from '../components/BeforeAfterSlider.astro';

const kategorien = [
  { key: 'alle',         label: 'Alle Projekte' },
  { key: 'gartenpflege', label: 'Gartenpflege' },
  { key: 'baumpflege',   label: 'Baumpflege' },
  { key: 'entruempelung', label: 'Entrümpelung' },
];

type Projekt = {
  title: string;
  description: string;
  kategorie: 'gartenpflege' | 'baumpflege' | 'entruempelung';
  leistung: string;
  alt: string;
} & (
  | { vorherNachher: false; image: string }
  | { vorherNachher: true; imageVorher: string; imageNachher: string }
);

