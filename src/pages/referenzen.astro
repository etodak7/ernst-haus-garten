    kategorie: 'gartenpflege',
    leistung: 'Heckenschnitt',
    imageVorher: '/images/referenzen/heckenschnitt-eingang-vor.webp',
    imageNachher: '/images/referenzen/heckenschnitt-eingang-nach.webp',
    alt: 'Heckenschnitt am Eingangsbereich vorher und nachher',
