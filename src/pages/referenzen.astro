const leistungColors: Record<string, string> = {
  'Heckenschnitt':     'text-green-700 bg-green-100',
  'Gehölzschnitt':     'text-green-700 bg-green-100',
  'Gartenpflege':      'text-green-700 bg-green-100',
  'Baumpflege':        'text-earth-700 bg-earth-100',
  'Entrümpelung':      'text-earth-700 bg-earth-100',
  'Haushaltsauflösung':'text-earth-700 bg-earth-100',
  'Räumung':           'text-earth-700 bg-earth-100',
};
---

<BaseLayout
  title="Referenzen – ERNST HAUS & GARTEN"
  description="Echte Projekte aus der Region: Heckenschnitt, Gartenpflege, Baumarbeiten und Räumungen in Marienheide und Umgebung."
  canonical="/referenzen"
>

  <!-- Breadcrumb -->
  <div class="bg-warm-gray-50 border-b border-warm-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3">
      <nav class="text-sm text-warm-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-green-700 transition-colors">Startseite</a></li>
          <li class="text-warm-gray-300">/</li>
          <li class="text-warm-gray-700 font-medium">Referenzen</li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- Header -->
  <section class="bg-warm-white border-b border-warm-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 sm:py-14">
      <div class="inline-flex items-center gap-2 text-sm font-medium text-green-700 bg-green-50 px-3 py-1.5 rounded-full mb-5 border border-green-200">
        <span class="material-symbols-outlined text-[1rem]" aria-hidden="true">photo_library</span>
        Echte Projekte aus der Region
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-warm-gray-900 leading-tight">Unsere Referenzen</h1>
      <p class="mt-3 text-base sm:text-lg text-warm-gray-600 max-w-2xl leading-relaxed">
        Keine gestellten Fotos, keine erfundenen Bewertungen. Hier sehen Sie echte Projekte – so wie sie in der Region ausgesehen haben.
      </p>
    </div>
  </section>

  <!-- Filter + Grid -->
  <section class="bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-10 sm:py-14">

      <!-- Kategorie-Filter -->
      <div class="flex flex-wrap gap-2 mb-10" role="tablist" aria-label="Projekte filtern">
        {kategorien.map((k, i) => (
          <button
            data-filter={k.key}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
            class:list={[
              'filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all border',
              i === 0
                ? 'bg-green-600 text-white border-green-600'
                : 'bg-white text-warm-gray-600 border-warm-gray-300 hover:border-green-400 hover:text-green-700',
            ]}
          >
            {k.label}
          </button>
        ))}
      </div>

      <!-- Masonry-Grid (natürliche Bildhöhen) -->
      <div id="projekte-grid" class="columns-1 sm:columns-2 lg:columns-3 gap-5">
        {projekte.map(p => (
          <div
            class="projekt-card break-inside-avoid mb-5 rounded-xl overflow-hidden border border-warm-gray-200 bg-white"
            data-kategorie={p.kategorie}
          >
            {p.vorherNachher ? (
              <BeforeAfterSlider
                imageVorher={p.imageVorher}
                imageNachher={p.imageNachher}
                alt={p.alt}
              />
            ) : (
              <div class="relative">
                <img
                  src={p.image}
                  alt={p.alt}
                  class="w-full h-auto block"
                  loading="lazy"
                />
              </div>
            )}
            <!-- Text -->
            <div class="p-4 sm:p-5">
              <span class:list={[
                'inline-block text-xs font-medium px-2.5 py-1 rounded-full mb-3',
                leistungColors[p.leistung] ?? 'text-warm-gray-600 bg-warm-gray-100',
              ]}>
                {p.leistung}
              </span>
              <h2 class="font-semibold text-warm-gray-900 text-base mb-1.5">{p.title}</h2>
              <p class="text-sm text-warm-gray-600 leading-relaxed">{p.description}</p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-green-50 border-t border-green-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-14 text-center">
      <h3 class="text-xl sm:text-2xl font-bold text-warm-gray-900 mb-3">Ihr Projekt als nächstes?</h3>
      <p class="text-base text-warm-gray-600 leading-relaxed mb-6 max-w-xl mx-auto">
        Schicken Sie uns Fotos per WhatsApp oder Formular – wir melden uns mit einer schnellen Einschätzung.
      </p>
      <Button href="/kontakt" variant="primary" size="large">Jetzt Projekt anfragen</Button>
    </div>
  </section>

</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.projekt-card');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => {
        b.classList.remove('bg-green-600', 'text-white', 'border-green-600');
        b.classList.add('bg-white', 'text-warm-gray-600', 'border-warm-gray-300');
        b.setAttribute('aria-selected', 'false');
      });
      btn.classList.add('bg-green-600', 'text-white', 'border-green-600');
      btn.classList.remove('bg-white', 'text-warm-gray-600', 'border-warm-gray-300');
      btn.setAttribute('aria-selected', 'true');

      const filter = btn.dataset.filter;
      items.forEach(item => {
        const show = filter === 'alle' || item.dataset.kategorie === filter;
        item.style.display = show ? '' : 'none';
      });
    });
  });
</script>
