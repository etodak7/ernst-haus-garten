---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/Section.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import Button from '../../components/Button.astro';

const houseServices = [
  {
    title: 'Entrümpelung & Haushaltsauflösung',
    description: 'Keller, Dachboden, Garage oder komplette Haushaltsauflösung – diskret, besenrein und zum Festpreis.',
    href: '/entruempelung',
    materialIcon: 'delete_sweep',
  },
  {
    title: 'Winterdienst & kleinere Außenarbeiten',
    description: 'Schneeräumung, Streuen, Rasenkanten und kleinere Pflasterausbesserungen – zuverlässig und pünktlich.',
    href: '/leistungen/winterdienst-aussenarbeiten',
    materialIcon: 'ac_unit',
  },
];

const gardenServices = [
  {
    title: 'Gartenpflege & Heckenschnitt',
    description: 'Regelmäßige Pflege, saubere Rückschnitte und ein gepflegter Außenbereich – für private Grundstücke und kleinere Objekte.',
    href: '/leistungen/gartenpflege-heckenschnitt',
    materialIcon: 'content_cut',
  },
  {
    title: 'Baumpflege & Fällarbeiten',
    description: 'Baumpflege und Fällarbeiten im zulässigen Rahmen – fachgerecht, umsichtig und mit Blick auf Sicherheit.',
    href: '/leistungen/baumpflege-faellarbeiten',
    materialIcon: 'park',
  },
];
---

<BaseLayout
  title="Leistungen – Gartenpflege, Entrümpelung & Winterdienst im Oberbergischen | ERNST HAUS & GARTEN"
  description="Zwei Säulen, ein Ansprechpartner: Gartenpflege, Baumpflege, Heckenschnitt, Entrümpelung, Haushaltsauflösung und Winterdienst im Oberbergischen Kreis."
  canonical="/leistungen"
>
  <!-- Breadcrumb -->
  <div class="bg-warm-gray-50 border-b border-warm-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3">
      <nav class="text-sm text-warm-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-green-700 transition-colors">Startseite</a></li>
          <li class="text-warm-gray-300">/</li>
          <li class="text-warm-gray-700 font-medium">Leistungen</li>
        </ol>
      </nav>
    </div>
  </div>

  <Section bg="white" padding="large">
    <SectionHeading
      tag="h1"
      title="Unsere Leistungen"
      subtitle="Zwei Säulen, ein Ansprechpartner: Wir übernehmen die Arbeiten rund ums Haus und rund um den Garten – ohne dass Sie mehrere Firmen koordinieren müssen."
    />

    <!-- Säule 1: Rund ums Haus -->
    <div class="mb-12 sm:mb-14">
      <div class="flex items-center gap-3 mb-6 pb-3 border-b-2 border-earth-200">
        <span class="material-symbols-outlined text-earth-700" style="font-size: 1.9rem;" aria-hidden="true">home</span>
        <h2 class="text-xl sm:text-2xl font-bold text-warm-gray-900">Rund ums Haus</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 sm:gap-6">
        {houseServices.map(service => (
          <ServiceCard {...service} variant="haus" />
        ))}
      </div>
    </div>

    <!-- Säule 2: Rund um den Garten -->
    <div>
      <div class="flex items-center gap-3 mb-6 pb-3 border-b-2 border-green-200">
        <span class="material-symbols-outlined text-green-700" style="font-size: 1.9rem;" aria-hidden="true">grass</span>
        <h2 class="text-xl sm:text-2xl font-bold text-warm-gray-900">Rund um den Garten</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 sm:gap-6">
        {gardenServices.map(service => (
          <ServiceCard {...service} variant="garten" />
        ))}
      </div>
    </div>

    <div class="mt-16 max-w-2xl mx-auto text-center">
      <p class="text-warm-gray-600 leading-relaxed">
        Sie sind sich nicht sicher, ob wir Ihnen bei Ihrem Anliegen helfen können? Schreiben Sie uns einfach – wir geben Ihnen gerne eine ehrliche Einschätzung.
      </p>
      <div class="mt-6 flex flex-col sm:flex-row justify-center gap-3">
        <Button href="/kontakt" variant="primary" size="large">Jetzt Anfrage senden</Button>
        <Button href="/fuer-unternehmen" variant="outline" size="large">Für Unternehmen</Button>
      </div>
    </div>
  </Section>
</BaseLayout>
