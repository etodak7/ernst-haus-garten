---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';

const phone = '+49 176 61331466';
const email = 'info@ernst-hausgarten.de';
const whatsappLink = 'https://wa.me/4917661331466';

const leistungen = [
  'Gartenpflege & Heckenschnitt',
  'Baumpflege & Fällarbeiten',
  'Entrümpelung & Haushaltsauflösung',
  'Winterdienst & Außenarbeiten',
  'Sonstiges',
];

const faqItems = [
  {
    question: 'Wie schnell melden Sie sich?',
    answer: 'In der Regel noch am gleichen Tag oder am nächsten Werktag. Bei dringenden Anfragen am besten direkt anrufen oder per WhatsApp schreiben.',
  },
  {
    question: 'Kann ich Fotos schicken?',
    answer: 'Ja, sehr gerne per WhatsApp. 2–3 Fotos helfen uns, den Aufwand schneller einzuschätzen und Ihnen eine erste Rückmeldung zu geben – ohne Vor-Ort-Termin.',
  },
  {
    question: 'Gibt es eine kostenlose Besichtigung?',
    answer: 'Bei größeren Arbeiten oder wenn eine Einschätzung anhand von Fotos nicht ausreicht, kommen wir gerne kostenlos vor Ort und schauen uns die Situation an.',
  },
];
---

<BaseLayout
  title="Kontakt – ERNST HAUS & GARTEN"
  description="Kontaktieren Sie ERNST HAUS & GARTEN für Gartenpflege, Entrümpelung und Außenarbeiten in Marienheide. Per Telefon, WhatsApp oder Kontaktformular."
  canonical="/kontakt"
>

  <!-- Breadcrumb -->
  <div class="bg-warm-gray-50 border-b border-warm-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3">
      <nav class="text-sm text-warm-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-green-700 transition-colors">Startseite</a></li>
          <li class="text-warm-gray-300">/</li>
          <li class="text-warm-gray-700 font-medium">Kontakt</li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- Page Hero -->
  <section class="bg-warm-white border-b border-warm-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
      <div class="max-w-2xl">
        <h1 class="text-3xl sm:text-4xl font-bold text-warm-gray-900 leading-tight">
          Kontakt aufnehmen
        </h1>
        <p class="mt-4 text-base sm:text-lg text-warm-gray-600 leading-relaxed">
          Schicken Sie uns Ihre Anfrage – per Telefon, WhatsApp oder Formular. Wir melden uns schnell.
        </p>
        <!-- Schnellkontakt-Chips -->
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={`tel:${phone.replace(/\s/g, '')}`}
            class="inline-flex items-center gap-2 px-4 py-2.5 bg-white border border-warm-gray-200 rounded-full text-sm font-medium text-warm-gray-700 hover:border-green-500 hover:text-green-700 transition-colors shadow-sm"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            Anrufen
          </a>
          <a href={whatsappLink} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2.5 bg-white border border-warm-gray-200 rounded-full text-sm font-medium text-warm-gray-700 hover:border-green-500 hover:text-green-700 transition-colors shadow-sm"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
          <a href={`mailto:${email}`}
            class="inline-flex items-center gap-2 px-4 py-2.5 bg-white border border-warm-gray-200 rounded-full text-sm font-medium text-warm-gray-700 hover:border-green-500 hover:text-green-700 transition-colors shadow-sm"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            E-Mail
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Formular + Sidebar -->
  <Section bg="white" padding="large">
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-16">

      <!-- Formular (links, 3 Spalten) -->
      <div class="lg:col-span-3">
        <h2 class="text-xl font-bold text-warm-gray-900 mb-6">Anfrage schreiben</h2>
        <form class="space-y-5" action="/api/kontakt.php" method="POST">
          <!-- Honeypot: echte Nutzer sehen das Feld nicht, Bots füllen es aus -->
          <div aria-hidden="true" style="position:absolute;left:-9999px;top:-9999px;width:1px;height:1px;overflow:hidden;">
            <label for="website">Website (nicht ausfüllen)</label>
            <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
          </div>
          <input type="hidden" name="ts" value="0" />
          <script is:inline>
            (function () {
              var ts = document.querySelector('form[action="/api/kontakt.php"] input[name="ts"]');
              if (ts) ts.value = Math.floor(Date.now() / 1000);
            })();
          </script>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-medium text-warm-gray-700 mb-1.5">Name *</label>
              <input type="text" id="name" name="name" required autocomplete="name"
                class="w-full px-4 py-3 border border-warm-gray-300 rounded-lg text-sm text-warm-gray-900 placeholder-warm-gray-400 focus:border-green-600 focus:ring-1 focus:ring-green-600 transition-colors"
                placeholder="Ihr Name"
              />
            </div>
            <div>
              <label for="telefon" class="block text-sm font-medium text-warm-gray-700 mb-1.5">Telefon <span class="text-warm-gray-400 font-normal">(optional)</span></label>
              <input type="tel" id="telefon" name="telefon" autocomplete="tel"
                class="w-full px-4 py-3 border border-warm-gray-300 rounded-lg text-sm text-warm-gray-900 placeholder-warm-gray-400 focus:border-green-600 focus:ring-1 focus:ring-green-600 transition-colors"
                placeholder="Für Rückruf"
              />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="email" class="block text-sm font-medium text-warm-gray-700 mb-1.5">E-Mail *</label>
              <input type="email" id="email" name="email" required autocomplete="email"
                class="w-full px-4 py-3 border border-warm-gray-300 rounded-lg text-sm text-warm-gray-900 placeholder-warm-gray-400 focus:border-green-600 focus:ring-1 focus:ring-green-600 transition-colors"
                placeholder="Ihre E-Mail-Adresse"
              />
            </div>
            <div>
              <label for="ort" class="block text-sm font-medium text-warm-gray-700 mb-1.5">Ort <span class="text-warm-gray-400 font-normal">(optional)</span></label>
              <input type="text" id="ort" name="ort"
                class="w-full px-4 py-3 border border-warm-gray-300 rounded-lg text-sm text-warm-gray-900 placeholder-warm-gray-400 focus:border-green-600 focus:ring-1 focus:ring-green-600 transition-colors"
                placeholder="z. B. Marienheide"
              />
            </div>
          </div>

          <div>
            <label for="leistung" class="block text-sm font-medium text-warm-gray-700 mb-1.5">Gewünschte Leistung</label>
            <select id="leistung" name="leistung"
              class="w-full px-4 py-3 border border-warm-gray-300 rounded-lg text-sm text-warm-gray-900 focus:border-green-600 focus:ring-1 focus:ring-green-600 transition-colors bg-white"
            >
              <option value="">Bitte auswählen</option>
              {leistungen.map(l => (
                <option value={l}>{l}</option>
              ))}
            </select>
          </div>

          <div>
            <label for="nachricht" class="block text-sm font-medium text-warm-gray-700 mb-1.5">Ihre Nachricht *</label>
            <textarea id="nachricht" name="nachricht" rows={5} required
              class="w-full px-4 py-3 border border-warm-gray-300 rounded-lg text-sm text-warm-gray-900 placeholder-warm-gray-400 focus:border-green-600 focus:ring-1 focus:ring-green-600 transition-colors resize-y"
              placeholder="Beschreiben Sie kurz Ihr Anliegen – z. B. Größe des Gartens, was gemacht werden soll, wann in etwa."
            ></textarea>
          </div>

          <div class="flex items-start gap-3">
            <input type="checkbox" id="datenschutz" name="datenschutz" required
              class="mt-0.5 h-4 w-4 rounded border-warm-gray-300 text-green-600 focus:ring-green-600 shrink-0"
            />
            <label for="datenschutz" class="text-sm text-warm-gray-600">
              Ich habe die <a href="/datenschutz" class="text-green-600 underline hover:text-green-700">Datenschutzerklärung</a> gelesen und bin mit der Verarbeitung meiner Daten einverstanden. *
            </label>
          </div>

          <div class="flex flex-col sm:flex-row items-start gap-4">
            <button type="submit"
              class="inline-flex items-center justify-center gap-2 bg-green-600 text-white font-semibold px-8 py-3.5 rounded-lg hover:bg-green-700 active:bg-green-800 transition-colors text-base"
            >
              Anfrage absenden
            </button>
            <p class="text-sm text-warm-gray-500 self-center">
              * Pflichtfeld
            </p>
          </div>

          <!-- Tipp -->
          <div class="flex items-start gap-3 p-4 bg-green-50 rounded-lg border border-green-100">
            <span class="material-symbols-outlined text-green-600 text-[1.1rem] mt-0.5 shrink-0" aria-hidden="true">tips_and_updates</span>
            <p class="text-sm text-green-800">
              <strong>Tipp:</strong> Fotos per WhatsApp geht schneller — schicken Sie 2–3 Bilder direkt an <a href={whatsappLink} class="underline hover:text-green-900" target="_blank" rel="noopener noreferrer">+49 176 61331466</a>.
            </p>
          </div>
        </form>
      </div>

      <!-- Sidebar (rechts, 2 Spalten) -->
      <div class="lg:col-span-2 space-y-6">
        <h2 class="text-xl font-bold text-warm-gray-900">Direkter Kontakt</h2>

        <!-- Telefon -->
        <a href={`tel:${phone.replace(/\s/g, '')}`}
          class="flex items-center gap-4 p-4 bg-warm-gray-50 rounded-xl hover:bg-warm-gray-100 transition-colors"
        >
          <div class="w-10 h-10 rounded-lg bg-green-100 text-green-700 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-medium text-warm-gray-500 uppercase tracking-wide">Telefon</p>
            <p class="font-semibold text-warm-gray-900">{phone}</p>
          </div>
        </a>

        <!-- WhatsApp -->
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer"
          class="flex items-center gap-4 p-4 bg-[#25D366]/8 rounded-xl hover:bg-[#25D366]/15 transition-colors"
        >
          <div class="w-10 h-10 rounded-lg bg-[#25D366]/20 text-[#128C7E] flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-medium text-warm-gray-500 uppercase tracking-wide">WhatsApp</p>
            <p class="font-semibold text-warm-gray-900">Fotos & Anfragen direkt</p>
          </div>
        </a>

        <!-- E-Mail -->
        <a href={`mailto:${email}`}
          class="flex items-center gap-4 p-4 bg-warm-gray-50 rounded-xl hover:bg-warm-gray-100 transition-colors"
        >
          <div class="w-10 h-10 rounded-lg bg-green-100 text-green-700 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <div>
            <p class="text-xs font-medium text-warm-gray-500 uppercase tracking-wide">E-Mail</p>
            <p class="font-semibold text-warm-gray-900">{email}</p>
          </div>
        </a>

        <!-- Erreichbarkeit -->
        <div class="p-4 bg-warm-gray-50 rounded-xl">
          <p class="text-xs font-medium text-warm-gray-500 uppercase tracking-wide mb-3">Erreichbarkeit</p>
          <dl class="space-y-1.5 text-sm">
            <div class="flex justify-between">
              <dt class="text-warm-gray-600">Mo – Fr</dt>
              <dd class="font-medium text-warm-gray-900">7:00 – 18:00 Uhr</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-warm-gray-600">Sa</dt>
              <dd class="font-medium text-warm-gray-900">8:00 – 14:00 Uhr</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-warm-gray-600">So</dt>
              <dd class="text-warm-gray-400">nicht erreichbar</dd>
            </div>
          </dl>
        </div>

        <!-- Einsatzgebiet -->
        <div class="p-4 bg-green-50 rounded-xl border border-green-100">
          <p class="text-xs font-medium text-green-700 uppercase tracking-wide mb-2">Einsatzgebiet</p>
          <p class="text-sm text-green-900 leading-relaxed">
            Marienheide und ca. 30 km Umkreis — Gummersbach, Wipperfürth, Bergneustadt, Meinerzhagen, Wiehl, Engelskirchen
          </p>
        </div>
      </div>
    </div>
  </Section>

  <!-- FAQ -->
  <section class="bg-warm-gray-50 border-y border-warm-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
      <h2 class="text-2xl font-bold text-warm-gray-900 mb-8">Häufige Fragen zur Kontaktaufnahme</h2>
      <div class="max-w-3xl space-y-4">
        {faqItems.map((item, i) => (
          <details class="group bg-white rounded-xl border border-warm-gray-200 overflow-hidden">
            <summary class="flex items-center justify-between gap-4 px-6 py-4 cursor-pointer list-none font-semibold text-warm-gray-900 hover:text-green-700 transition-colors">
              {item.question}
              <span class="material-symbols-outlined text-warm-gray-400 group-open:rotate-180 transition-transform duration-200 shrink-0 text-[1.25rem]" aria-hidden="true">expand_more</span>
            </summary>
            <div class="px-6 pb-5 text-base text-warm-gray-600 leading-relaxed border-t border-warm-gray-100 pt-4">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-earth-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 sm:py-16 text-center">
      <p class="text-earth-300 text-sm font-medium uppercase tracking-wider mb-3">Lieber direkt?</p>
      <p class="text-3xl sm:text-4xl font-bold text-white mb-2">{phone}</p>
      <p class="text-earth-300 text-base mb-8">Einfach anrufen — wir sind Mo–Fr von 7 bis 18 Uhr erreichbar.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-3 sm:gap-4">
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2.5 bg-[#25D366] text-white font-semibold px-7 py-3.5 rounded-lg hover:bg-[#20ba5a] transition-colors text-base"
          aria-label="Anfrage per WhatsApp senden"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp starten
        </a>
        <a href={`tel:${phone.replace(/\s/g, '')}`}
          class="inline-flex items-center justify-center gap-2.5 bg-white/10 text-white font-semibold px-7 py-3.5 rounded-lg hover:bg-white/20 transition-colors border border-white/20 text-base"
          aria-label="Jetzt anrufen"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Jetzt anrufen
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
