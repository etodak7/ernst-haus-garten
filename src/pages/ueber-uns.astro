---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import Button from '../components/Button.astro';

const phone = '+49 176 61331466';
const whatsappLink = 'https://wa.me/4917661331466';

const werte = [
  {
    icon: 'handshake',
    title: 'Zuverlässigkeit',
    text: 'Termine werden eingehalten. Was vereinbart wurde, wird gemacht – nicht mehr, nicht weniger.',
    color: 'earth',
  },
  {
    icon: 'cleaning_services',
    title: 'Saubere Ausführung',
    text: 'Nach der Arbeit sieht es besser aus als vorher. Wir räumen auf und hinterlassen keine Baustelle.',
    color: 'green',
  },
  {
    icon: 'person',
    title: 'Direkter Kontakt',
    text: 'Kein Callcenter, keine Subunternehmer. Sie sprechen direkt mit Alexander Ernst – der auch die Arbeit macht.',
    color: 'earth',
  },
];

const leistungen = [
  { icon: 'content_cut', title: 'Gartenpflege & Heckenschnitt', href: '/leistungen/gartenpflege-heckenschnitt' },
  { icon: 'park', title: 'Baumpflege & Fällarbeiten', href: '/leistungen/baumpflege-faellarbeiten' },
  { icon: 'delete_sweep', title: 'Entrümpelung & Haushaltsauflösung', href: '/leistungen/entruempelung-haushaltsaufloesung' },
  { icon: 'ac_unit', title: 'Winterdienst & Außenarbeiten', href: '/leistungen/winterdienst-aussenarbeiten' },
];

const regionen = ['Marienheide', 'Gummersbach', 'Wipperfürth', 'Bergneustadt', 'Meinerzhagen', 'Wiehl', 'Engelskirchen'];
---

<BaseLayout
  title="Über uns – ERNST HAUS & GARTEN"
  description="ERNST HAUS & GARTEN: Ihr direkter Ansprechpartner für Gartenpflege, Baumpflege und Entrümpelung in Marienheide. Regional, zuverlässig, persönlich."
  canonical="/ueber-uns"
>

  <!-- Breadcrumb -->
  <div class="bg-warm-gray-50 border-b border-warm-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3">
      <nav class="text-sm text-warm-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-green-700 transition-colors">Startseite</a></li>
          <li class="text-warm-gray-300">/</li>
          <li class="text-warm-gray-700 font-medium">Über uns</li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="bg-warm-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 sm:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

        <!-- Foto -->
        <div class="order-2 lg:order-1">
          <div class="bg-warm-gray-100 rounded-2xl aspect-square w-full max-w-md mx-auto lg:mx-0 flex items-center justify-center">
            <div class="text-center p-8">
              <span class="material-symbols-outlined text-warm-gray-300 block mx-auto mb-3" style="font-size: 5rem;" aria-hidden="true">person</span>
              <p class="text-sm text-warm-gray-400">Foto folgt</p>
            </div>
          </div>
        </div>

        <!-- Text -->
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center gap-2 text-sm font-medium text-earth-600 bg-earth-50 px-3 py-1.5 rounded-full mb-5 border border-earth-200">
            <span class="material-symbols-outlined text-[1rem]" aria-hidden="true">location_on</span>
            Gegründet in Marienheide
          </div>

          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-warm-gray-900 leading-tight">
            Ein Betrieb.<br />Ein Ansprechpartner.
          </h1>

          <div class="mt-6 space-y-4 text-base sm:text-lg text-warm-gray-600 leading-relaxed">
            <p>
              Mein Name ist Alexander Ernst. Ich führe ERNST HAUS & GARTEN als Einzelbetrieb in Marienheide – und mache die Arbeit selbst.
            </p>
            <p>
              Keine Subunternehmer, keine Durchlauferhitzer. Wenn Sie anrufen, sprechen Sie mit mir. Wenn wir einen Termin ausmachen, komme ich. Wenn die Arbeit fertig ist, sieht es aus wie vereinbart.
            </p>
          </div>

          <div class="mt-8">
            <Button href="/kontakt" variant="primary" size="large">Anfrage stellen</Button>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Wie wir arbeiten -->
  <Section bg="white">
    <div class="mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold text-warm-gray-900">Wie wir arbeiten</h2>
      <p class="mt-3 text-base text-warm-gray-600 max-w-2xl">
        Drei Dinge, auf die Sie sich verlassen können – egal ob es um Heckenschnitt, Baumfällung oder eine Entrümpelung geht.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {werte.map(w => (
        <div class={`p-6 rounded-xl ${w.color === 'green' ? 'bg-green-50 border border-green-100' : 'bg-earth-50 border border-earth-100'}`}>
          <span class={`material-symbols-outlined text-[2.25rem] mb-4 block ${w.color === 'green' ? 'text-green-600' : 'text-earth-600'}`} aria-hidden="true">{w.icon}</span>
          <h3 class="font-semibold text-warm-gray-900 mb-2">{w.title}</h3>
          <p class="text-base text-warm-gray-600 leading-relaxed">{w.text}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Einsatzgebiet -->
  <section class="bg-warm-gray-50 border-y border-warm-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-start">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-warm-gray-900 mb-4">Unser Einsatzgebiet</h2>
          <p class="text-base text-warm-gray-600 leading-relaxed">
            Wir sind in Marienheide und im Umkreis von ca. 30 km für private Kunden im Einsatz. Kurze Wege bedeuten schnelle Reaktionszeiten – und keine Anfahrtskosten, die das Angebot unnötig verteuern.
          </p>
          <p class="mt-4 text-sm text-warm-gray-500">
            Ihr Ort ist nicht dabei? Fragen Sie trotzdem an – wir schauen, ob wir helfen können.
          </p>
        </div>
        <div class="flex flex-wrap gap-2.5">
          {regionen.map(region => (
            <span class="inline-flex items-center gap-1.5 bg-white text-green-800 text-sm font-medium px-4 py-2 rounded-full border border-green-200 shadow-sm">
              <svg class="w-3.5 h-3.5 text-green-500" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
              {region}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Leistungsüberblick -->
  <Section bg="white">
    <div class="mb-10">
      <h2 class="text-2xl sm:text-3xl font-bold text-warm-gray-900">Was wir anbieten</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {leistungen.map(l => (
        <a href={l.href}
          class="group flex items-start gap-4 p-5 bg-warm-gray-50 rounded-xl border border-warm-gray-200 hover:border-green-400 hover:bg-green-50 transition-colors"
        >
          <span class="material-symbols-outlined text-green-600 text-[1.75rem] shrink-0 group-hover:text-green-700 transition-colors" aria-hidden="true">{l.icon}</span>
          <div>
            <p class="font-medium text-warm-gray-900 text-sm leading-snug group-hover:text-green-800 transition-colors">{l.title}</p>
            <span class="text-xs text-green-600 mt-1 inline-flex items-center gap-0.5 group-hover:gap-1.5 transition-all">
              Mehr erfahren
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </div>
        </a>
      ))}
    </div>
    <div class="mt-8">
      <Button href="/leistungen" variant="outline">Alle Leistungen ansehen</Button>
    </div>
  </Section>

  <!-- Bottom CTA -->
  <section class="bg-earth-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 sm:py-16 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-white leading-tight">
        Sprechen Sie uns direkt an.
      </h2>
      <p class="mt-3 text-earth-300 text-base max-w-xl mx-auto">
        Kein Formular nötig — einfach anrufen oder eine WhatsApp schicken. Wir melden uns.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3 sm:gap-4">
        <a href={whatsappLink} target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2.5 bg-[#25D366] text-white font-semibold px-7 py-3.5 rounded-lg hover:bg-[#20ba5a] transition-colors text-base"
          aria-label="Anfrage per WhatsApp senden"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp starten
        </a>
        <a href={`tel:${phone.replace(/\s/g, '')}`}
          class="inline-flex items-center justify-center gap-2.5 bg-white/10 text-white font-semibold px-7 py-3.5 rounded-lg hover:bg-white/20 transition-colors border border-white/20 text-base"
          aria-label="Jetzt anrufen"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          {phone}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
