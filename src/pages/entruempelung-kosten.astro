---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';
import FAQ from '../components/FAQ.astro';

const whatsappLink = 'https://wa.me/4917661331466';
const phone = '+49 176 61331466';

// Preis-Richtwerte — absichtlich als Rahmen, nicht als fixe Preisliste
const priceRanges = [
  {
    situation: 'Einzelner Keller / Dachboden',
    description: 'Ein typischer Hauskeller mit altem Hausrat, Sperrmüll, ein paar Möbeln',
    range: 'ab ~300 €',
    typical: '500 – 1.200 €',
    icon: 'home',
  },
  {
    situation: 'Garage / Schuppen / Gartenhaus',
    description: 'Von Werkzeug und Altreifen bis zur kompletten Einrichtung eines Gartenhauses',
    range: 'ab ~400 €',
    typical: '500 – 1.500 €',
    icon: 'garage',
  },
  {
    situation: 'Einzelraum (Zimmer)',
    description: 'Ein komplett ausgeräumtes Zimmer — Möbel, Textilien, persönliche Gegenstände',
    range: 'ab ~250 €',
    typical: '300 – 700 €',
    icon: 'inventory_2',
  },
  {
    situation: '1–2 Zimmer-Wohnung',
    description: 'Komplette Räumung inklusive Küche und Bad, besenreine Übergabe',
    range: 'ab ~800 €',
    typical: '1.200 – 2.500 €',
    icon: 'inventory_2',
  },
  {
    situation: '3–4 Zimmer-Wohnung',
    description: 'Familien-Wohnung mit kompletter Einrichtung, meist 1–2 Arbeitstage',
    range: 'ab ~1.500 €',
    typical: '2.000 – 4.000 €',
    icon: 'delete_sweep',
  },
  {
    situation: 'Komplettes Haus / große Wohnung',
    description: 'Einfamilienhaus oder größere Wohnung mit Keller und Dachboden',
    range: 'ab ~2.500 €',
    typical: '3.500 – 7.000 €',
    icon: 'delete_sweep',
  },
  {
    situation: 'Messiewohnung',
    description: 'Stark vermüllte Wohnung mit Gefahrstoffen, Ungeziefer oder Spezialreinigung',
    range: 'auf Anfrage',
    typical: 'stark individuell',
    icon: 'cleaning_services',
  },
  {
    situation: 'Nachlass / Haushaltsauflösung',
    description: 'Komplette Auflösung nach Todesfall inkl. Sortierung, Wertanrechnung und Entsorgungsnachweis',
    range: 'ab ~1.500 €',
    typical: 'je nach Umfang',
    icon: 'handshake',
  },
];

const priceFactors = [
  {
    icon: 'inventory_2',
    title: 'Menge & Volumen',
    text: 'Wie viel Hausrat, Möbel und Sperrmüll muss raus? Faustregel: je mehr, desto mehr Arbeitszeit und mehr Fahrten zum Wertstoffhof.',
  },
  {
    icon: 'home',
    title: 'Zugänglichkeit',
    text: 'Parterre mit Parkplatz vor der Tür ist einfach. Fünfter Stock ohne Aufzug, enge Zufahrt oder keine Parkmöglichkeit erhöhen den Aufwand deutlich.',
  },
  {
    icon: 'delete_sweep',
    title: 'Art der Gegenstände',
    text: 'Normaler Hausrat ist unkompliziert. Sondermüll, Asbest, Öle, Farben oder große Mengen Elektroschrott brauchen gesonderte Entsorgung — das kostet extra.',
  },
  {
    icon: 'schedule',
    title: 'Zeitdruck',
    text: 'Normaler Termin in 1–2 Wochen kostet weniger als ein Express-Einsatz am Wochenende. Kurzfristig geht, wird aber in der Kalkulation berücksichtigt.',
  },
  {
    icon: 'handshake',
    title: 'Wertanrechnung',
    text: 'Gut erhaltene Möbel, Antiquitäten, funktionstüchtige Geräte oder Sammlerstücke können wir gegen den Preis anrechnen. Das reduziert die Rechnung — manchmal deutlich.',
  },
];

const faqItems = [
  {
    question: 'Warum nennen Sie keine Festpreise auf der Website?',
    answer: 'Weil jede Entrümpelung anders ist. Eine 60-qm-Wohnung im Erdgeschoss mit Aufzug und leerer Parkzone kostet völlig anders als dieselbe Wohnung im fünften Stock ohne Lift. Feste Listenpreise würden bedeuten, dass die einen zu viel bezahlen und die anderen zu wenig. Deshalb machen wir jedes Mal einen individuellen Festpreis nach kurzer Besichtigung oder Foto-Einschätzung — und halten uns dann daran.',
  },
  {
    question: 'Wie bekomme ich einen verbindlichen Preis?',
    answer: 'Zwei Wege: (1) Schicken Sie uns 3–5 Fotos der betroffenen Räume per WhatsApp, wir melden uns meist binnen 24 Stunden mit einer ersten Einschätzung. (2) Bei größeren Objekten kommen wir zu einem kostenlosen Vor-Ort-Termin und geben Ihnen dann einen schriftlichen Festpreis. Danach richten wir uns — keine Nachforderungen.',
  },
  {
    question: 'Gibt es eine Pauschale pro Quadratmeter?',
    answer: 'Solche „pro-qm"-Rechner sind bequem, aber ungenau. Eine leere Wohnung mit Tapeten und ein bisschen Küchenzeug kostet ein Drittel von derselben Wohnung mit vollgestopftem Keller. Die Quadratmeterzahl ist nur einer von mehreren Faktoren. Ehrlicher ist eine echte Einschätzung statt einer Pi-mal-Daumen-Formel.',
  },
  {
    question: 'Was bedeutet „Wertanrechnung"?',
    answer: 'Wenn wir bei einer Entrümpelung Dinge finden, die einen realen Wiederverkaufswert haben — gut erhaltene Möbel, Antiquitäten, Designermöbel, funktionstüchtige Elektrogeräte, Werkzeug, Schmuck, Sammlerstücke — können wir deren Wert auf den Gesamtpreis anrechnen. In manchen Fällen reduziert das den Endpreis um mehrere hundert oder sogar tausend Euro. Sie entscheiden vorher, was anrechenbar sein soll und was Sie behalten möchten.',
  },
  {
    question: 'Ist ein Container günstiger als eine Komplett-Entrümpelung?',
    answer: 'Nicht unbedingt. Ein Container kostet Miete, Anlieferung, Abholung und Entsorgungsgebühr nach Gewicht. Dazu kommt, dass Sie das Ausräumen selbst machen müssen. Bei kleineren Mengen (Garage, Keller) kann ein Container sinnvoll sein. Bei Wohnungen oder Häusern ist die Komplett-Entrümpelung meist günstiger und immer bequemer — wir räumen, laden und entsorgen in einem Zug.',
  },
  {
    question: 'Was kostet eine Messiewohnung?',
    answer: 'Da ist ein Pauschalpreis seriös nicht möglich. Messiewohnungen variieren stark: von „stark vollgestellt" bis „Gesundheitsgefahr durch Schädlinge und Sondermüll". Der Preis hängt von Volumen, Gefahrstoffen, Spezialreinigung und notwendigen Schutzmaßnahmen ab. Wir kommen diskret zu einer Besichtigung und nennen Ihnen dann einen verbindlichen Festpreis — ohne Urteil und ohne Vorhaltungen.',
  },
  {
    question: 'Verlangen Sie eine Anzahlung?',
    answer: 'Bei kleineren Aufträgen (bis ca. 1.000 €) nicht — Sie zahlen nach Abschluss. Bei größeren Projekten können wir eine Teilzahlung vereinbaren, wenn Sie das bevorzugen. Die Rechnung erhalten Sie entweder vor Ort direkt nach der Arbeit oder per Mail hinterher — ganz wie es für Sie passt.',
  },
  {
    question: 'Erhalte ich eine richtige Rechnung für die Steuererklärung?',
    answer: 'Ja, selbstverständlich. Die Rechnung enthält alle Angaben, die Sie für eine steuerliche Geltendmachung brauchen. Entrümpelungs- und Räumungskosten können bei Nachlässen, Umzügen oder bestimmten Sonderfällen steuerlich relevant sein — sprechen Sie im Zweifel mit Ihrem Steuerberater.',
  },
];
---

<BaseLayout
  title="Was kostet eine Entrümpelung? – Preise, Faktoren & Festpreis-Versprechen | ERNST HAUS & GARTEN"
  description="Ehrliche Orientierungswerte für Entrümpelungs-Kosten im Oberbergischen: vom Keller bis zur kompletten Haushaltsauflösung. Festpreis vorab, keine Nachforderungen, Wertanrechnung möglich."
  canonical="/entruempelung-kosten"
>

  <!-- Breadcrumb -->
  <div class="bg-warm-gray-50 border-b border-warm-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3">
      <nav class="text-sm text-warm-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-green-700 transition-colors">Startseite</a></li>
          <li class="text-warm-gray-300">/</li>
          <li><a href="/entruempelung" class="hover:text-green-700 transition-colors">Entrümpelung</a></li>
          <li class="text-warm-gray-300">/</li>
          <li class="text-warm-gray-700 font-medium">Kosten</li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- HERO -->
  <section class="bg-warm-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-20 lg:py-24">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 text-sm font-medium text-green-700 bg-green-50 px-3 py-1.5 rounded-full mb-5 border border-green-200">
          <span class="material-symbols-outlined text-[1rem]" aria-hidden="true">payments</span>
          Kosten & Preise
        </div>
        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-warm-gray-900 leading-tight">
          Was kostet eine Entrümpelung?
        </h1>
        <p class="mt-4 text-xl sm:text-2xl font-semibold text-green-700 leading-snug">
          Ehrliche Antworten statt versteckter Überraschungen.
        </p>
        <p class="mt-5 sm:mt-6 text-base sm:text-lg text-warm-gray-600 leading-relaxed">
          Die kurze Antwort - es kommt darauf an. Die lange Antwort steht auf dieser Seite: Orientierungswerte für typische Situationen, die fünf Faktoren, die den Preis wirklich bestimmen, und unser Versprechen - Festpreis vorab, keine Nachforderungen.
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <Button href="/kontakt" variant="primary" size="large">Festpreis anfragen</Button>
          <a
            href={whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2.5 bg-[#25D366] text-white font-semibold px-7 py-3.5 rounded-lg hover:bg-[#20ba5a] transition-colors text-base"
            aria-label="Fotos per WhatsApp schicken"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Fotos per WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ORIENTIERUNGSWERTE -->
  <Section bg="light">
    <SectionHeading
      title="Orientierungswerte für typische Situationen"
      subtitle="Das sind realistische Rahmen, keine Festpreise. Der echte Preis für Ihre konkrete Situation kommt nach Fotos oder einer kurzen Besichtigung — und bleibt dann wie vereinbart."
    />

    <div class="max-w-5xl mx-auto">
      <div class="bg-white rounded-2xl border border-warm-gray-200 overflow-hidden shadow-sm">
        <div class="divide-y divide-warm-gray-100">
          {priceRanges.map(row => (
            <div class="px-5 sm:px-6 py-5 flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-6">
              <div class="flex items-start gap-3 flex-1 min-w-0">
                <span class="material-symbols-outlined text-green-600 shrink-0 mt-0.5" style="font-size: 1.5rem;" aria-hidden="true">{row.icon}</span>
                <div class="flex-1 min-w-0">
                  <div class="font-semibold text-warm-gray-900 text-sm sm:text-base">{row.situation}</div>
                  <div class="text-xs sm:text-sm text-warm-gray-500 mt-1 leading-snug">{row.description}</div>
                </div>
              </div>
              <div class="flex flex-col sm:items-end gap-0.5 sm:min-w-[160px] pl-9 sm:pl-0">
                <div class="text-xs text-warm-gray-500 uppercase tracking-wider">Üblicher Rahmen</div>
                <div class="text-sm font-bold text-warm-gray-900 whitespace-nowrap">{row.typical}</div>
                <div class="text-xs text-earth-700 font-medium">{row.range}</div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-6 p-5 bg-earth-50 border border-earth-100 rounded-xl flex items-start gap-3">
        <span class="material-symbols-outlined text-earth-700 shrink-0 mt-0.5" style="font-size: 1.4rem;" aria-hidden="true">visibility</span>
        <p class="text-sm text-warm-gray-700 leading-relaxed">
          <strong class="font-semibold text-warm-gray-900">Wichtig:</strong> Diese Werte sind Orientierungshilfen für gängige Situationen im Oberbergischen und Märkischen Raum. Ihr konkreter Preis hängt von den fünf Faktoren unten ab &mdash; und wird immer als <strong class="font-semibold text-warm-gray-900">verbindlicher Festpreis</strong> vor Beginn der Arbeit festgelegt.
        </p>
      </div>
    </div>
  </Section>

  <!-- PREIS-FAKTOREN -->
  <Section bg="white">
    <SectionHeading
      title="Die 5 Faktoren, die den Preis bestimmen"
      subtitle="Statt starren Pauschalen nach Quadratmeter erklären wir lieber offen, was wir wirklich in die Kalkulation einrechnen."
    />
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
      {priceFactors.map((f, i) => (
        <div class="bg-white p-7 rounded-2xl border border-warm-gray-200 hover:border-green-300 hover:shadow-md transition-all">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-lg bg-green-50 flex items-center justify-center shrink-0">
              <span class="material-symbols-outlined text-green-700" style="font-size: 1.5rem;" aria-hidden="true">{f.icon}</span>
            </div>
            <div class="text-xs font-bold text-warm-gray-500 uppercase tracking-wider">Faktor {i + 1}</div>
          </div>
          <h3 class="text-lg font-semibold text-warm-gray-900 mb-2">{f.title}</h3>
          <p class="text-sm text-warm-gray-600 leading-relaxed">{f.text}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- WERTANRECHNUNG HIGHLIGHT -->
  <Section bg="light">
    <div class="max-w-4xl mx-auto">
      <div class="bg-gradient-to-br from-green-50 to-warm-gray-50 border-2 border-green-200 rounded-3xl p-8 sm:p-10">
        <div class="flex flex-col sm:flex-row items-start gap-6">
          <div class="w-16 h-16 rounded-2xl bg-green-600 flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-white" style="font-size: 2rem;" aria-hidden="true">handshake</span>
          </div>
          <div class="flex-1">
            <h2 class="text-2xl sm:text-3xl font-bold text-warm-gray-900 leading-tight mb-4">
              Wertanrechnung — der Preis kann sinken, manchmal deutlich
            </h2>
            <p class="text-base sm:text-lg text-warm-gray-700 leading-relaxed mb-4">
              In vielen Haushalten finden wir Dinge mit echtem Wiederverkaufswert: gut erhaltene Möbel, Antiquitäten, Designermöbel, funktionstüchtige Elektrogeräte, Werkzeug, Schmuck, Porzellan oder Sammlerstücke. Wenn Sie damit einverstanden sind, rechnen wir den Wert auf die Entrümpelungskosten an.
            </p>
            <p class="text-base sm:text-lg text-warm-gray-700 leading-relaxed">
              <strong class="font-semibold text-warm-gray-900">Das Ergebnis:</strong> In manchen Fällen reduziert die Wertanrechnung die Rechnung um mehrere hundert bis zu mehreren tausend Euro &mdash; je nach Fund. Sie entscheiden vorher, was wir anrechnen dürfen und was Sie behalten möchten.
            </p>
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- FESTPREIS-VERSPRECHEN -->
  <section class="bg-earth-800 text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
      <div class="max-w-3xl mx-auto text-center">
        <span class="material-symbols-outlined text-green-400 mb-4" style="font-size: 3rem;" aria-hidden="true">check_circle</span>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white leading-tight mb-5">
          Unser Festpreis-Versprechen
        </h2>
        <p class="text-base sm:text-lg text-earth-200 leading-relaxed mb-8">
          Nach Fotos oder einer kurzen Besichtigung nennen wir Ihnen einen <strong class="font-semibold text-white">verbindlichen Festpreis</strong>. Danach richten wir uns. Keine Nachforderungen wegen „unerwarteter" Menge, keine Überraschungsgebühren, keine schleichenden Zusatzkosten. Wenn der Preis steht, dann steht er.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-left max-w-2xl mx-auto">
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-green-400 shrink-0" style="font-size: 1.5rem;" aria-hidden="true">check_circle</span>
            <div>
              <div class="font-semibold text-white text-sm">Schriftlich</div>
              <div class="text-xs text-earth-300 mt-0.5">Festpreis per E-Mail oder vor Ort</div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-green-400 shrink-0" style="font-size: 1.5rem;" aria-hidden="true">check_circle</span>
            <div>
              <div class="font-semibold text-white text-sm">Bindend</div>
              <div class="text-xs text-earth-300 mt-0.5">Was vereinbart ist, gilt</div>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <span class="material-symbols-outlined text-green-400 shrink-0" style="font-size: 1.5rem;" aria-hidden="true">check_circle</span>
            <div>
              <div class="font-semibold text-white text-sm">Transparent</div>
              <div class="text-xs text-earth-300 mt-0.5">Alles aufgeschlüsselt, nichts versteckt</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <Section bg="light">
    <SectionHeading
      title="Häufige Fragen zu den Kosten"
      subtitle="Die Fragen, die Leute uns am häufigsten stellen, bevor sie anfragen."
    />
    <div class="max-w-3xl mx-auto">
      <FAQ items={faqItems} />
    </div>
  </Section>

  <!-- BOTTOM CTA -->
  <section class="bg-earth-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-20 text-center">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white leading-tight max-w-2xl mx-auto">
        Sie wollen einen konkreten Preis für Ihre Situation?
      </h2>
      <p class="mt-4 text-earth-300 text-base sm:text-lg max-w-xl mx-auto">
        Schicken Sie uns 3&ndash;5 Fotos per WhatsApp &mdash; wir melden uns meist binnen 24 Stunden mit einem verbindlichen Festpreis.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3 sm:gap-4">
        <Button href={whatsappLink} variant="whatsapp" size="large" external ariaLabel="Anfrage per WhatsApp senden">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Fotos per WhatsApp
        </Button>
        <Button href={`tel:${phone.replace(/\s/g, '')}`} variant="secondary" size="large" class="!bg-white/10 !text-white !border-white/30 hover:!bg-white/20" ariaLabel="Jetzt anrufen">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Jetzt anrufen
        </Button>
