---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ServiceCard from '../components/ServiceCard.astro';
import StepCard from '../components/StepCard.astro';
import Button from '../components/Button.astro';
import FAQ from '../components/FAQ.astro';
import BeforeAfterSlider from '../components/BeforeAfterSlider.astro';

const whatsappLink = 'https://wa.me/4917661331466';
const phone = '+49 176 61331466';


const houseServices = [
  {
    title: 'Entrümpelung & Haushaltsauflösung',
    description: 'Keller, Dachboden, Garage oder komplette Haushaltsauflösung – diskret, besenrein und zum Festpreis.',
    href: '/entruempelung',
    materialIcon: 'delete_sweep',
  },
  {
    title: 'Winterdienst & kleinere Außenarbeiten',
    description: 'Schneeräumung, Streuen, Rasenkanten und kleinere Pflasterausbesserungen – zuverlässig und pünktlich.',
    href: '/leistungen/winterdienst-aussenarbeiten',
    materialIcon: 'ac_unit',
  },
];

const gardenServices = [
  {
    title: 'Gartenpflege & Heckenschnitt',
    description: 'Regelmäßige Pflege, saubere Rückschnitte und ein gepflegter Außenbereich – für private Grundstücke und kleinere Objekte.',
    href: '/leistungen/gartenpflege-heckenschnitt',
    materialIcon: 'content_cut',
  },
  {
    title: 'Baumpflege & Fällarbeiten',
    description: 'Baumpflege und Fällarbeiten im zulässigen Rahmen – fachgerecht, umsichtig und mit Blick auf Sicherheit.',
    href: '/leistungen/baumpflege-faellarbeiten',
    materialIcon: 'park',
  },
];

const trustPoints = [
  {
    title: 'Regional und erreichbar',
    text: 'Wir arbeiten in Marienheide und im Umkreis von etwa 30 km. Kurze Wege, direkte Kommunikation.',
  },
  {
    title: 'Klare Absprachen',
    text: 'Sie wissen vorher, was gemacht wird und was es kostet. Keine versteckten Extras.',
  },
  {
    title: 'Saubere Ausführung',
    text: 'Wir hinterlassen Ihren Garten und Außenbereich ordentlich – nicht halbfertig.',
  },
  {
    title: 'Direkter Ansprechpartner',
    text: 'Keine Callcenter-Schleifen. Sie sprechen direkt mit den Leuten, die auch die Arbeit machen.',
  },
];

const regions = [
  'Marienheide',
  'Gummersbach',
  'Wipperfürth',
  'Bergneustadt',
  'Meinerzhagen',
  'Wiehl',
  'Engelskirchen',
];

const faqItems = [
  {
    question: 'In welchem Gebiet arbeiten Sie?',
    answer: 'Wir sind in Marienheide und im Umkreis von etwa 30 km im Einsatz – unter anderem in Gummersbach, Wipperfürth, Bergneustadt, Meinerzhagen, Wiehl und Engelskirchen.',
  },
  {
    question: 'Kann ich Fotos per WhatsApp schicken?',
    answer: 'Ja, sehr gerne. Schicken Sie uns einfach 2–3 Fotos per WhatsApp. Das hilft uns, den Aufwand schneller einzuschätzen und Ihnen eine erste Rückmeldung zu geben.',
  },
  {
    question: 'Bieten Sie Besichtigungen an?',
    answer: 'Bei größeren Arbeiten oder wenn eine Einschätzung anhand von Fotos nicht ausreicht, kommen wir gerne vorbei und schauen uns die Situation vor Ort an.',
  },
  {
    question: 'Machen Sie auch kurzfristige Entrümpelungen?',
    answer: 'Wir bemühen uns, auch kurzfristige Anfragen zeitnah zu bedienen. Kontaktieren Sie uns am besten direkt telefonisch oder per WhatsApp, damit wir die Verfügbarkeit klären können.',
  },
  {
    question: 'Welche kleineren Außenarbeiten übernehmen Sie?',
    answer: 'Dazu gehören zum Beispiel Rasenkanten setzen, kleinere Pflaster- und Plattenarbeiten, Ausbesserungen im Außenbereich und ähnliche Instandsetzungsarbeiten.',
  },
  {
    question: 'Führen Sie Baumfällarbeiten durch?',
    answer: 'Ja, wir führen Baumpflege und Fällarbeiten im zulässigen Rahmen durch. Bei der Ausführung berücksichtigen wir die geltenden Vorgaben und achten auf Sicherheit.',
  },
  {
    question: 'Übernehmen Sie regelmäßige Gartenpflege?',
    answer: 'Ja, wir bieten regelmäßige Gartenpflege an – zum Beispiel saisonale Mäharbeiten, Heckenschnitt und Gehölzpflege. Sprechen Sie uns einfach auf einen passenden Rhythmus an.',
  },
];
---

<BaseLayout
  title="ERNST HAUS & GARTEN – Gartenpflege, Entrümpelung & Winterdienst im Oberbergischen"
  description="Gartenpflege, Entrümpelung, Haushaltsauflösung, Baumpflege und Winterdienst im Oberbergischen – Gummersbach, Lüdenscheid, Wipperfürth & Umgebung. Zuverlässig, diskret, regional. Jetzt anfragen."
  canonical="/"
>

  <!-- Hero -->
  <section class="bg-green-50 border-b border-green-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 pb-12 sm:pb-20 lg:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 sm:gap-12 lg:gap-16 items-center">

        <!-- Text -->
        <div>
          <div class="inline-flex items-center gap-2 text-sm font-medium text-green-700 mb-5">
            <span class="material-symbols-outlined text-[1.1rem]" aria-hidden="true">location_on</span>
            Familienbetrieb aus Marienheide · tätig im Oberbergischen
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-warm-gray-900 leading-tight">
            Gartenpflege, Entrümpelung & Winterdienst &ndash; Ihr Haus &amp; Garten Partner im Oberbergischen
          </h1>
          <p class="mt-5 sm:mt-6 text-base sm:text-lg text-warm-gray-600 leading-relaxed">
            Zwei Welten, ein Ansprechpartner: <strong class="font-semibold text-warm-gray-900">rund ums Haus</strong> &ndash; Entrümpelung, Haushaltsauflösung, Winterdienst. Und <strong class="font-semibold text-warm-gray-900">rund um den Garten</strong> &ndash; Gartenpflege, Heckenschnitt, Baumpflege. Zuverlässig, diskret und mit klarer Absprache vorab.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-3 sm:gap-4">
            <Button href="/kontakt" variant="primary" size="large">Jetzt anfragen</Button>
            <Button href="/leistungen" variant="secondary" size="large">Leistungen ansehen</Button>
          </div>

          <!-- Trust Badges -->
          <div class="mt-10 flex flex-wrap gap-5">
            {[
              { icon: 'location_on', label: 'Regional tätig' },
              { icon: 'chat', label: 'WhatsApp möglich' },
              { icon: 'person', label: 'Persönliche Abstimmung' },
              { icon: 'visibility', label: 'Besichtigung auf Wunsch' },
            ].map(({ icon, label }) => (
              <span class="flex items-center gap-2 text-sm text-warm-gray-600">
                <span class="material-symbols-outlined text-green-600 text-[1.1rem]" aria-hidden="true">{icon}</span>
                {label}
              </span>
            ))}
          </div>
        </div>

        <!-- Hero-Bild: ein großes Foto, mobil oben, Desktop rechts -->
        <div class="relative order-first lg:order-none">
          <div class="relative -mx-4 sm:-mx-6 lg:mx-0 lg:rounded-2xl overflow-hidden lg:shadow-lg lg:ring-1 lg:ring-warm-gray-200/50">
            <img
              src="/images/hero-garten.webp"
              alt="Gepflegter Garten mit Sträuchern und Heckenelementen in Marienheide"
              class="w-full h-64 sm:h-80 lg:h-[30rem] object-cover"
              loading="eager"
              fetchpriority="high"
            />
            <!-- Sanfter Verlauf für besseren Badge-Kontrast -->
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/40 to-transparent pointer-events-none"></div>
            <!-- Floating Badge — Link zu den Referenzen -->
            <a
              href="/referenzen"
              class="group absolute bottom-4 left-4 sm:bottom-5 sm:left-5 lg:bottom-6 lg:left-6 bg-white/95 backdrop-blur-sm rounded-xl px-4 py-3 shadow-lg flex items-center gap-3 max-w-[calc(100%-2rem)] hover:bg-white hover:shadow-xl transition-all duration-200"
              aria-label="Alle Referenz-Projekte ansehen"
            >
              <span class="material-symbols-outlined text-green-600 text-[1.6rem]" aria-hidden="true">photo_library</span>
              <div class="leading-tight flex-1">
                <div class="text-sm font-semibold text-warm-gray-900 group-hover:text-green-700 transition-colors">Alle Projekte ansehen</div>
                <div class="text-xs text-warm-gray-600">Echte Referenzen aus der Region</div>
              </div>
              <span class="material-symbols-outlined text-green-600 text-[1.2rem] group-hover:translate-x-0.5 transition-transform" aria-hidden="true">arrow_forward</span>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Leistungsüberblick – zwei Säulen: Haus und Garten -->
  <Section id="leistungen" bg="white">
    <SectionHeading
      title="Unsere Leistungen"
      subtitle="Zwei Säulen, ein Ansprechpartner: Wir übernehmen die Arbeiten rund ums Haus und rund um den Garten – ohne dass Sie mehrere Firmen koordinieren müssen."
    />

    <!-- Säule 1: Rund ums Haus -->
    <div class="mb-12 sm:mb-14">
      <div class="flex items-center gap-3 mb-6 pb-3 border-b-2 border-earth-200">
        <span class="material-symbols-outlined text-earth-700" style="font-size: 1.9rem;" aria-hidden="true">home</span>
        <h3 class="text-xl sm:text-2xl font-bold text-warm-gray-900">Rund ums Haus</h3>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 sm:gap-6">
        {houseServices.map(service => (
          <ServiceCard {...service} variant="haus" />
        ))}
      </div>
    </div>

    <!-- Säule 2: Rund um den Garten -->
    <div>
      <div class="flex items-center gap-3 mb-6 pb-3 border-b-2 border-green-200">
        <span class="material-symbols-outlined text-green-700" style="font-size: 1.9rem;" aria-hidden="true">grass</span>
        <h3 class="text-xl sm:text-2xl font-bold text-warm-gray-900">Rund um den Garten</h3>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 sm:gap-6">
        {gardenServices.map(service => (
          <ServiceCard {...service} variant="garten" />
        ))}
      </div>
    </div>
  </Section>

  <!-- Warum ERNST HAUS & GARTEN -->
  <Section bg="light">
    <SectionHeading
      title="Warum ERNST HAUS & GARTEN?"
      subtitle="Bei uns bekommen Sie keine überladene Großfirma-Struktur, sondern direkte Abstimmung, verlässliche Termine und einen Ansprechpartner, der weiß, worauf es vor Ort ankommt."
    />
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
      {trustPoints.map(point => (
        <div class="text-center">
          <span class="material-symbols-outlined text-green-600 mb-3 block mx-auto" style="font-size: 2.75rem;" aria-hidden="true">check_circle</span>
          <h3 class="font-semibold text-warm-gray-900 mb-1 text-sm sm:text-base">{point.title}</h3>
          <p class="text-sm sm:text-base text-warm-gray-600 leading-relaxed">{point.text}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- Referenzen / Vorher-Nachher -->
  <Section bg="white">
    <SectionHeading
      title="Einblicke in unsere Arbeit"
      subtitle="Echte Projekte aus der Region – Heckenschnitt, Gartenpflege und Gehölzarbeiten."
    />
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
      {[
        {
          image: '/images/referenzen/heckenschnitt-vorher-nachher-nach.webp',
          alt: 'Sauber geschnittene Koniferen-Hecke nach Formschnitt',
          label: 'Heckenschnitt',
          text: 'Koniferen-Hecke auf Maß zurückgeschnitten',
        },
        {
          image: '/images/referenzen/gartenpflege-wildwuchs-nach.webp',
          alt: 'Verwilderter Garten freigeschnitten und aufgeräumt',
          label: 'Gartenpflege',
          text: 'Wildwuchs beseitigt, Fläche wieder nutzbar',
        },
        {
          image: '/images/referenzen/baumarbeiten-collage-tr.webp',
          alt: 'Sturmschaden-Einsatz: Baum wird kontrolliert vom Carport abgetragen',
          label: 'Notfällung',
          text: 'Sturmschaden: Baum aufs Carport gestürzt, kontrolliert abgetragen',
        },
      ].map(item => (
        <div class="flex flex-col rounded-xl overflow-hidden border border-warm-gray-200 bg-white">
          <div class="aspect-[4/3] overflow-hidden">
            <img
              src={item.image}
              alt={item.alt}
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="bg-warm-gray-50 p-4 flex-1">
            <p class="font-medium text-warm-gray-900 text-sm">{item.label}</p>
            <p class="text-sm text-warm-gray-500">{item.text}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="text-center mt-8">
      <Button href="/referenzen" variant="outline">Alle Referenzen ansehen</Button>
    </div>
  </Section>

  <!-- So läuft's ab -->
  <Section bg="green">
    <SectionHeading
      title="So läuft's ab"
      subtitle="Schicken Sie uns Ihre Anfrage gern direkt per WhatsApp oder Formular – idealerweise mit 2–3 Fotos. So können wir den Aufwand schneller einschätzen."
    />
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-12">
      <StepCard step={1} title="Anfrage senden" description="Per Telefon, WhatsApp oder Kontaktformular. Ein paar Fotos helfen bei der Einschätzung." materialIcon="contact_support" />
      <StepCard step={2} title="Rückmeldung & Einschätzung" description="Wir melden uns zeitnah. Bei Bedarf kommen wir für eine Besichtigung vor Ort." materialIcon="search" />
      <StepCard step={3} title="Termin & Umsetzung" description="Wir vereinbaren einen Termin und führen die Arbeiten zuverlässig und sauber durch." materialIcon="construction" />
    </div>
  </Section>

  <!-- Einsatzgebiet -->
  <Section bg="white">
    <SectionHeading
      title="Für Marienheide und die Region"
      subtitle="Wir sind in Marienheide und im Umkreis von etwa 30 km für private Kunden und kleinere Objekte im Einsatz."
    />
    <div class="flex flex-wrap justify-center gap-3">
      {regions.map(region => (
        <span class="inline-flex items-center gap-1.5 bg-green-50 text-green-800 text-sm font-medium px-4 py-2 rounded-full border border-green-200">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
          </svg>
          {region}
        </span>
      ))}
    </div>
    <p class="text-center text-sm text-warm-gray-500 mt-6">
      Ihr Ort ist nicht dabei? Fragen Sie gerne an – oft sind wir auch in der weiteren Umgebung im Einsatz.
    </p>
  </Section>

  <!-- FAQ -->
  <Section bg="light">
    <SectionHeading
      title="Häufige Fragen"
      subtitle="Die wichtigsten Antworten auf einen Blick."
    />
    <div class="max-w-3xl mx-auto">
      <FAQ items={faqItems} />
    </div>
  </Section>

  <!-- Abschluss-CTA -->
  <section class="bg-earth-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-20 text-center">
      <h2 class="text-2xl sm:text-3xl font-bold text-white leading-tight max-w-2xl mx-auto">
        Garten pflegen, Wohnung räumen oder Schnee schippen lassen?
      </h2>
      <p class="mt-4 text-earth-300 text-base sm:text-lg max-w-xl mx-auto">
        Ein Ansprechpartner für alles rund ums Haus und den Garten. Schicken Sie uns einfach Ihre Anfrage – telefonisch, per WhatsApp oder über das Formular.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3 sm:gap-4">
        <Button href={whatsappLink} variant="whatsapp" size="large" external ariaLabel="Anfrage per WhatsApp senden">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp starten
        </Button>
        <Button href={`tel:${phone.replace(/\s/g, '')}`} variant="secondary" size="large" class="!bg-white/10 !text-white !border-white/30 hover:!bg-white/20" ariaLabel="Jetzt anrufen">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          Jetzt anrufen
        </Button>
        <Button href="/kontakt" variant="secondary" size="large" class="!bg-white/10 !text-white !border-white/30 hover:!bg-white/20">
          Anfrage senden
        </Button>
      </div>
    </div>
  </section>

</BaseLayout>
