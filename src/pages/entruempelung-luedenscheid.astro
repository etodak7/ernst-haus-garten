---
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';
import FAQ from '../components/FAQ.astro';

const whatsappLink = 'https://wa.me/4917661331466';
const phone = '+49 176 61331466';

const services = [
  {
    icon: 'home',
    title: 'Keller & Dachboden',
    text: 'Ausräumen, Sperrmüll und Altlasten entfernen, fachgerecht entsorgen. Auch nach jahrzehntelanger Standzeit.',
  },
  {
    icon: 'garage',
    title: 'Garage & Schuppen',
    text: 'Vom alten Reifenstapel bis zum kompletten Gartenhaus – wir räumen Außenanlagen leer und hinterlassen sie besenrein.',
  },
  {
    icon: 'inventory_2',
    title: 'Komplette Wohnung',
    text: 'Miet- oder Eigentumswohnungen jeder Größe. Inklusive Abbau von Einbaumöbeln und kleineren Demontagearbeiten.',
  },
  {
    icon: 'delete_sweep',
    title: 'Haushaltsauflösung',
    text: 'Ganzes Haus, komplette Wohnung – wir übernehmen Inhalt, Entsorgung und die besenreine Übergabe.',
  },
  {
    icon: 'cleaning_services',
    title: 'Messiewohnung',
    text: 'Diskret und ohne Vorurteile. Wir arbeiten mit der nötigen Ruhe und bringen das Objekt wieder in einen vorzeigbaren Zustand.',
  },
  {
    icon: 'handshake',
    title: 'Nachlass & Erbfall',
    text: 'Einfühlsame Räumung nach einem Todesfall. Wertanrechnung auf Wunsch, alles mit Respekt vor den Verstorbenen und Angehörigen.',
  },
];

const trustPoints = [
  { icon: 'payments', text: 'Festpreis vorab — keine Nachforderungen' },
  { icon: 'cleaning_services', text: 'Besenreine Übergabe inklusive' },
  { icon: 'description', text: 'Entsorgungsnachweise auf Wunsch' },
  { icon: 'person', text: 'Direkter Ansprechpartner, kein Callcenter' },
];

const steps = [
  {
    num: 1,
    icon: 'photo_library',
    title: 'Fotos per WhatsApp',
    text: 'Schicken Sie uns 2–3 Bilder der betroffenen Räume. Oft reicht das für eine erste Einschätzung.',
  },
  {
    num: 2,
    icon: 'search',
    title: 'Besichtigung & Festpreis',
    text: 'Bei größeren Projekten kommen wir vorbei, schauen uns alles an und nennen einen Festpreis.',
  },
  {
    num: 3,
    icon: 'construction',
    title: 'Termin & Räumung',
    text: 'Wir räumen zum vereinbarten Termin – pünktlich, diskret und in einem Zug.',
  },
  {
    num: 4,
    icon: 'check_circle',
    title: 'Besenrein & Nachweis',
    text: 'Übergabe im sauberen Zustand. Entsorgungsnachweise erhalten Sie auf Wunsch mit der Rechnung.',
  },
];

const stadtteile = [
  'Lüdenscheid-Innenstadt',
  'Brügge',
  'Hellersen',
  'Kluse',
  'Oberrahmede',
  'Honsel',
  'Bierbaum',
  'Wehberg',
];

const faqItems = [
  {
    question: 'Wie oft kommen Sie nach Lüdenscheid?',
    answer: 'Regelmäßig – Lüdenscheid ist einer unserer Schwerpunkt-Orte jenseits des Oberbergischen Kreises. Die Anfahrt von Marienheide dauert etwa 25 bis 30 Minuten. Bei größeren Projekten planen wir diese Zeit gleich mit ein, damit sie sich weder in der Rechnung noch im Termin niederschlägt.',
  },
  {
    question: 'Lüdenscheid ist im Märkischen Kreis — arbeiten Sie da trotzdem?',
    answer: 'Absolut. Die Kreisgrenze zwischen Oberberg und Märkisch ist für uns nur Verwaltung, keine praktische Hürde. Wir übernehmen in Lüdenscheid genauso zuverlässig wie in Gummersbach oder Marienheide. Festpreis vorab, besenreine Übergabe, alles wie gewohnt.',
  },
  {
    question: 'In welchen Stadtteilen von Lüdenscheid arbeiten Sie?',
    answer: 'Überall — Innenstadt, Brügge, Hellersen, Kluse, Oberrahmede, Honsel, Bierbaum, Wehberg und die umliegenden Nachbarschaften. Bei sehr abgelegenen Randlagen melden wir uns mit einer realistischen Einschätzung der Fahrtzeit, damit Sie wissen, woran Sie sind.',
  },
  {
    question: 'Was kostet eine Entrümpelung in Lüdenscheid?',
    answer: 'Die Kosten hängen von Menge, Zugänglichkeit (Stockwerk, Aufzug, Parkmöglichkeit) und Art der Gegenstände ab. Wir machen Ihnen nach Fotos oder einer kurzen Besichtigung einen verbindlichen Festpreis, der auch die Anfahrt aus Marienheide fair einrechnet. Keine Nachforderungen.',
  },
  {
    question: 'Was passiert mit verwertbaren Sachen? Gibt es eine Wertanrechnung?',
    answer: 'Gut erhaltene Möbel, Antiquitäten oder andere verwertbare Gegenstände können wir auf die Gesamtkosten anrechnen. In manchen Fällen reduziert das den Preis deutlich. Sie entscheiden vorher, was mit eventuell wertvollen Dingen passieren soll.',
  },
  {
    question: 'Erhalte ich einen Entsorgungsnachweis?',
    answer: 'Ja, auf Wunsch gerne. Wir entsorgen fachgerecht über zugelassene Stellen in der Region und dokumentieren die Entsorgungswege. Besonders für Hausverwaltungen, Makler und Nachlassverwalter in Lüdenscheid ist das oft wichtig.',
  },
  {
    question: 'Machen Sie das auch für Hausverwaltungen und Makler in Lüdenscheid?',
    answer: 'Ja. Wir übernehmen Auflösungen und Räumungen für Hausverwaltungen (besenreine Übergaben zwischen Mietern), Makler (Objekt-Aufbereitung vor Verkauf) und Nachlassverwalter (diskrete Räumungen mit Wertanrechnung und Entsorgungsnachweis). Rechnung auf Firma selbstverständlich. Mehr dazu auf unserer Seite „Für Unternehmen".',
  },
];
---

<BaseLayout
  title="Entrümpelung Lüdenscheid – diskret, Festpreis, besenrein | ERNST HAUS & GARTEN"
  description="Entrümpelung und Haushaltsauflösung in Lüdenscheid und allen Stadtteilen. Festpreis vorab, besenreine Übergabe, planbare Termine. Regelmäßig vor Ort im Märkischen Kreis."
  canonical="/entruempelung-luedenscheid"
>

  <!-- Breadcrumb -->
  <div class="bg-warm-gray-50 border-b border-warm-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3">
      <nav class="text-sm text-warm-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-green-700 transition-colors">Startseite</a></li>
          <li class="text-warm-gray-300">/</li>
          <li><a href="/entruempelung" class="hover:text-green-700 transition-colors">Entrümpelung</a></li>
          <li class="text-warm-gray-300">/</li>
          <li class="text-warm-gray-700 font-medium">Lüdenscheid</li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- HERO -->
  <section class="bg-warm-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-20 lg:py-24">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

        <!-- Text -->
        <div>
          <div class="inline-flex items-center gap-2 text-sm font-medium text-green-700 bg-green-50 px-3 py-1.5 rounded-full mb-5 border border-green-200">
            <span class="material-symbols-outlined text-[1rem]" aria-hidden="true">location_on</span>
            Entrümpelung in Lüdenscheid
          </div>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-warm-gray-900 leading-tight">
            Entrümpelung in Lüdenscheid &ndash; <span class="text-green-700">regelmäßig vor Ort, auch jenseits der Kreisgrenze</span>
          </h1>
          <p class="mt-5 sm:mt-6 text-base sm:text-lg text-warm-gray-600 leading-relaxed max-w-xl">
            Lüdenscheid ist einer unserer Schwerpunkt-Orte im Märkischen Kreis &mdash; rund 25 km von unserem Sitz in Marienheide. Wir sind hier regelmäßig unterwegs, ob Wohnungsauflösung in der Innenstadt, Kellerräumung in Brügge oder ein größerer Auftrag in Hellersen. Die Kreisgrenze ist für uns nur Verwaltung.
          </p>

          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <Button href="/kontakt" variant="primary" size="large">Anfrage senden</Button>
            <a
              href={whatsappLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2.5 bg-[#25D366] text-white font-semibold px-7 py-3.5 rounded-lg hover:bg-[#20ba5a] transition-colors text-base"
              aria-label="Fotos per WhatsApp schicken"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Per WhatsApp Fotos schicken
            </a>
          </div>

          <!-- Trust Chips -->
          <div class="mt-10 grid grid-cols-2 gap-x-6 gap-y-3 max-w-lg">
            <div class="flex items-center gap-2 text-sm font-medium text-warm-gray-700">
              <span class="material-symbols-outlined text-green-600 text-[1.1rem]" aria-hidden="true">schedule</span>
              Planbare Termine
            </div>
            <div class="flex items-center gap-2 text-sm font-medium text-warm-gray-700">
              <span class="material-symbols-outlined text-green-600 text-[1.1rem]" aria-hidden="true">payments</span>
              Festpreis vorab
            </div>
            <div class="flex items-center gap-2 text-sm font-medium text-warm-gray-700">
              <span class="material-symbols-outlined text-green-600 text-[1.1rem]" aria-hidden="true">cleaning_services</span>
              Besenreine Übergabe
            </div>
            <div class="flex items-center gap-2 text-sm font-medium text-warm-gray-700">
              <span class="material-symbols-outlined text-green-600 text-[1.1rem]" aria-hidden="true">description</span>
              Entsorgungsnachweis
            </div>
          </div>
        </div>

        <!-- Rechte Karte: Familienbetrieb + Distanz -->
        <div class="relative order-first lg:order-none">
          <div class="relative bg-gradient-to-br from-earth-50 to-warm-gray-100 rounded-2xl aspect-square flex items-center justify-center overflow-hidden">
            <span class="material-symbols-outlined text-earth-700/20" style="font-size: 18rem;" aria-hidden="true">delete_sweep</span>
            <div class="absolute bottom-5 left-5 right-5 bg-white/95 backdrop-blur-sm rounded-xl p-4 shadow-sm">
              <p class="text-sm font-semibold text-warm-gray-900">Familienbetrieb aus Marienheide</p>
              <p class="text-xs text-warm-gray-600 mt-0.5">~25 km nach Lüdenscheid &middot; regelmäßig im Märkischen Kreis</p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- B2B-Callout-Strip -->
  <section class="bg-earth-50 border-y border-earth-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3 sm:gap-4 text-sm sm:text-base">
        <div class="flex items-center gap-2.5 text-warm-gray-800">
          <span class="material-symbols-outlined text-earth-700 shrink-0" style="font-size: 1.4rem;" aria-hidden="true">work</span>
          <span>Sie verwalten Objekte in Lüdenscheid? <strong class="font-semibold">Wir übernehmen auch Gewerbe-Aufträge.</strong></span>
        </div>
        <a
          href="/fuer-unternehmen"
          class="inline-flex items-center gap-1.5 text-earth-800 font-semibold hover:text-earth-900 whitespace-nowrap group"
        >
          Für Unternehmen
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- LEISTUNGS-GRID -->
  <Section bg="light">
    <SectionHeading
      title="Was wir in Lüdenscheid räumen"
      subtitle="Ob Einzelraum oder komplettes Haus – wir haben für jede typische Räumungssituation eine Lösung."
    />
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
      {services.map(service => (
        <div class="bg-white p-7 rounded-2xl border border-warm-gray-200 hover:border-green-300 hover:shadow-md transition-all">
          <span class="material-symbols-outlined text-green-600 mb-4 block" style="font-size: 2.5rem;" aria-hidden="true">{service.icon}</span>
          <h3 class="text-lg font-semibold text-warm-gray-900 mb-2">{service.title}</h3>
          <p class="text-warm-gray-600 leading-relaxed text-sm">{service.text}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- LOKALER ANKER: Wir sind regelmäßig in Lüdenscheid -->
  <Section bg="white">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center max-w-5xl mx-auto">
      <div>
        <div class="inline-flex items-center gap-2 text-xs font-semibold text-earth-700 bg-earth-50 px-3 py-1.5 rounded-full border border-earth-200 uppercase tracking-wider mb-4">
          <span class="material-symbols-outlined text-[1rem]" aria-hidden="true">location_on</span>
          Vor Ort in Lüdenscheid
        </div>
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-warm-gray-900 leading-tight mb-5">
          Wir sind regelmäßig in Lüdenscheid unterwegs
        </h2>
        <p class="text-base sm:text-lg text-warm-gray-600 leading-relaxed mb-4">
          Lüdenscheid ist unser größter Zielmarkt im Märkischen Kreis &mdash; etwa 25 km Fahrtzeit von unserem Sitz in Marienheide. Wir sind hier regelmäßig für private Kunden und kleinere Gewerbeaufträge unterwegs und planen bei größeren Projekten die Anfahrt fair mit ein.
        </p>
        <p class="text-base sm:text-lg text-warm-gray-600 leading-relaxed">
          Das heißt für Sie: <strong class="font-semibold text-warm-gray-900">planbare Termine</strong>, kein übertriebener Anfahrtsaufpreis, und die Gewissheit, dass ein Anruf genauso zuverlässig beantwortet wird wie bei einem Nachbarort.
        </p>
      </div>
      <div class="bg-warm-gray-50 border border-warm-gray-200 rounded-2xl p-8">
        <h3 class="text-lg font-semibold text-warm-gray-900 mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-green-600" style="font-size: 1.5rem;" aria-hidden="true">home</span>
          Stadtteile, in denen wir arbeiten
        </h3>
        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-y-2.5 gap-x-4">
          {stadtteile.map(teil => (
            <li class="flex items-start gap-2 text-sm text-warm-gray-700">
              <svg class="w-4 h-4 text-green-600 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              <span>{teil}</span>
            </li>
          ))}
        </ul>
        <p class="text-xs text-warm-gray-500 mt-5 pt-4 border-t border-warm-gray-200">
          Ihr Stadtteil ist nicht dabei? Rufen Sie trotzdem an &mdash; bei abgelegeneren Lagen nennen wir Ihnen vorab eine realistische Einschätzung zur Fahrtzeit.
        </p>
      </div>
    </div>
  </Section>

  <!-- WARUM WIR -->
  <Section bg="light">
    <div class="max-w-5xl mx-auto">
      <div class="bg-white border border-warm-gray-200 rounded-3xl p-8 sm:p-10 shadow-sm">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 items-center">
          {trustPoints.map(point => (
            <div class="flex flex-col items-center text-center gap-3">
              <span class="material-symbols-outlined text-green-600" style="font-size: 2rem;" aria-hidden="true">{point.icon}</span>
              <p class="font-semibold text-warm-gray-900 text-sm leading-snug">{point.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </Section>

  <!-- PROZESS -->
  <section class="bg-earth-800 text-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
      <div class="text-center mb-12 sm:mb-16 max-w-2xl mx-auto">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white leading-tight">
          In 4 Schritten zum geräumten Objekt
        </h2>
        <p class="mt-4 text-earth-200 text-base sm:text-lg">
          Unser Ablauf ist transparent und unkompliziert &mdash; egal ob für einen Keller in Brügge oder eine Haushaltsauflösung in der Lüdenscheider Innenstadt.
        </p>
      </div>

      <div class="relative">
        <div class="hidden lg:block absolute top-10 left-[12.5%] right-[12.5%] h-0.5 bg-earth-600/50"></div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-6 relative">
          {steps.map(step => (
            <div class="flex flex-col items-center text-center relative">
              <div class="relative z-10 w-20 h-20 rounded-full bg-green-600 flex items-center justify-center mb-5 border-4 border-earth-800">
                <span class="material-symbols-outlined text-white" style="font-size: 2rem;" aria-hidden="true">{step.icon}</span>
              </div>
              <div class="inline-flex items-center gap-2 text-xs font-semibold text-earth-300 uppercase tracking-wider mb-2">
                Schritt {step.num}
              </div>
              <h3 class="text-lg font-semibold text-white mb-2">{step.title}</h3>
              <p class="text-sm text-earth-200 leading-relaxed">{step.text}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <Section bg="light">
    <SectionHeading
      title="Häufige Fragen — Entrümpelung in Lüdenscheid"
      subtitle="Die wichtigsten Antworten speziell für Lüdenscheid und Umgebung. Was hier fehlt, fragen Sie einfach direkt."
    />

    <!-- Kosten-Seite Cross-Link -->
    <div class="max-w-3xl mx-auto mb-8">
      <a
        href="/entruempelung-kosten"
        class="group block bg-white border-2 border-green-200 rounded-2xl p-5 hover:border-green-400 hover:shadow-md transition-all"
      >
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-green-50 flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-green-700" style="font-size: 1.5rem;" aria-hidden="true">payments</span>
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-semibold text-warm-gray-900">Was kostet eine Entrümpelung?</div>
            <div class="text-sm text-warm-gray-600 mt-0.5">Orientierungswerte, Einflussfaktoren und Festpreis-Versprechen im Detail.</div>
          </div>
          <span class="material-symbols-outlined text-green-700 shrink-0 group-hover:translate-x-0.5 transition-transform" aria-hidden="true">arrow_forward</span>
        </div>
      </a>
    </div>

    <div class="max-w-3xl mx-auto">
      <FAQ items={faqItems} />
    </div>
  </Section>

  <!-- BOTTOM CTA -->
  <section class="bg-earth-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-20 text-center">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-white leading-tight max-w-2xl mx-auto">
        Räumung in Lüdenscheid? Kreisgrenze egal, Zuverlässigkeit nicht.
      </h2>
      <p class="mt-4 text-earth-300 text-base sm:text-lg max-w-xl mx-auto">
        Schicken Sie uns Fotos per WhatsApp &mdash; wir melden uns zeitnah mit einer ehrlichen Einschätzung und vereinbaren einen Termin.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3 sm:gap-4">
        <Button href={whatsappLink} variant="whatsapp" size="large" external ariaLabel="Anfrage per WhatsApp senden">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
