---
interface Props {
  id?: string;
  bg?: 'white' | 'light' | 'green' | 'dark';
  padding?: 'normal' | 'large';
  class?: string;
}

const { id, bg = 'white', padding = 'normal', class: className } = Astro.props;

const bgClasses: Record<string, string> = {
  white: 'bg-white',
  light: 'bg-warm-gray-50',
  green: 'bg-green-50',
  dark: 'bg-warm-gray-900 text-white',
};

const paddingClasses: Record<string, string> = {
  normal: 'py-16 sm:py-20',
  large: 'py-20 sm:py-28',
};
---

<section id={id} class:list={[bgClasses[bg], paddingClasses[padding], className]}>
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <slot />
  </div>
</section>
