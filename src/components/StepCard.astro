---
interface Props {
  step: number;
  title: string;
  description: string;
}

const { step, title, description } = Astro.props;
---

<div class="text-center">
  <div class="w-12 h-12 rounded-full bg-green-600 text-white font-bold text-lg flex items-center justify-center mx-auto mb-4">
    {step}
  </div>
  <h3 class="font-semibold text-warm-gray-900 text-lg mb-2">{title}</h3>
  <p class="text-base text-warm-gray-600 leading-relaxed">{description}</p>
</div>
