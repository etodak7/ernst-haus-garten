---
interface Props {
  step: number;
  title: string;
  description: string;
  materialIcon?: string;
}

const { step, title, description, materialIcon } = Astro.props;
---

<div class="bg-white rounded-xl p-8 text-center shadow-sm">
  <div class="w-12 h-12 rounded-full bg-green-600 text-white font-bold text-lg flex items-center justify-center mx-auto mb-4">
    {step}
  </div>
  {materialIcon && (
    <span class="material-symbols-outlined text-green-600 mb-4 block" style="font-size: 2.25rem;" aria-hidden="true">{materialIcon}</span>
  )}
  <h3 class="font-semibold text-warm-gray-900 text-lg mb-2">{title}</h3>
  <p class="text-base text-warm-gray-600 leading-relaxed">{description}</p>
</div>
