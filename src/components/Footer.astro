---
const currentYear = new Date().getFullYear();
const phone = '+49 176 61331466';
const email = 'info@ernst-hausgarten.de';
const whatsappLink = 'https://wa.me/4917661331466';
---

<footer class="bg-earth-900 text-earth-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Spalte 1: Marke -->
      <div class="sm:col-span-2 lg:col-span-1">
        <span class="text-white font-bold text-lg tracking-tight">ERNST HAUS & GARTEN</span>
        <p class="mt-3 text-base leading-relaxed text-earth-400">
          Gartenpflege, Baumpflege und Entrümpelung in Marienheide und Umgebung.
        </p>
      </div>

      <!-- Spalte 2: Leistungen -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Leistungen</h3>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/leistungen/gartenpflege-heckenschnitt" class="hover:text-white transition-colors">Gartenpflege & Heckenschnitt</a></li>
          <li><a href="/leistungen/baumpflege-faellarbeiten" class="hover:text-white transition-colors">Baumpflege & Fällarbeiten</a></li>
          <li><a href="/entruempelung" class="hover:text-white transition-colors">Entrümpelung</a></li>
          <li class="pl-3 border-l border-earth-800">
            <a href="/entruempelung-gummersbach" class="text-xs text-earth-500 hover:text-earth-200 transition-colors">— Gummersbach</a>
          </li>
          <li class="pl-3 border-l border-earth-800">
            <a href="/entruempelung-luedenscheid" class="text-xs text-earth-500 hover:text-earth-200 transition-colors">— Lüdenscheid</a>
          </li>
          <li class="pl-3 border-l border-earth-800">
            <a href="/entruempelung-kosten" class="text-xs text-earth-500 hover:text-earth-200 transition-colors">— Kosten & Preise</a>
          </li>
          <li><a href="/leistungen/winterdienst-aussenarbeiten" class="hover:text-white transition-colors">Winterdienst & Außenarbeiten</a></li>
          <li class="pt-2 mt-2 border-t border-earth-800">
            <a href="/fuer-unternehmen" class="hover:text-white transition-colors flex items-center gap-1.5">
              Für Unternehmen
              <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </li>
        </ul>
      </div>

      <!-- Spalte 3: Kontakt -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Kontakt</h3>
        <ul class="space-y-2.5 text-sm">
          <li>
            <a href={`tel:${phone.replace(/\s/g, '')}`} class="hover:text-white transition-colors">
              {phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${email}`} class="hover:text-white transition-colors">
              {email}
            </a>
          </li>
          <li>
            <a href={whatsappLink} target="_blank" rel="noopener noreferrer" class="hover:text-white transition-colors">
              WhatsApp-Anfrage
            </a>
          </li>
          <li class="pt-1">
            <a href="/kontakt" class="hover:text-white transition-colors">
              Kontaktformular
            </a>
          </li>
        </ul>
      </div>

      <!-- Spalte 4: Region -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4">Einsatzgebiet</h3>
        <p class="text-sm leading-relaxed text-earth-400">
          Marienheide, Gummersbach, Wipperfürth, Bergneustadt, Meinerzhagen, Wiehl, Engelskirchen
        </p>
      </div>
    </div>

    <!-- Untere Zeile -->
    <div class="mt-12 pt-8 border-t border-earth-800 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-earth-400">
      <p>&copy; {currentYear} ERNST HAUS & GARTEN. Alle Rechte vorbehalten.</p>
      <div class="flex gap-6">
        <a href="/impressum" class="hover:text-earth-200 transition-colors">Impressum</a>
        <a href="/datenschutz" class="hover:text-earth-200 transition-colors">Datenschutz</a>
      </div>
    </div>
  </div>
</footer>
