---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from './Button.astro';

interface SubService {
  icon: string;
  title: string;
  text: string;
}

interface Step {
  title: string;
  text: string;
}

interface Example {
  image: string;
  alt: string;
  label: string;
  text: string;
}

interface Props {
  title: string;
  metaTitle: string;
  metaDescription: string;
  canonical: string;
  headline: string;
  tagline?: string;
  intro: string;
  items: string[];
  ctaLabel: string;
  ctaText?: string;
  image?: string;
  imageAlt?: string;
  subServices?: SubService[];
  steps?: Step[];
  examples?: Example[];
}

const {
  title, metaTitle, metaDescription, canonical,
  headline, tagline, intro, items, ctaLabel, ctaText,
  image, imageAlt, subServices, steps, examples,
} = Astro.props;

const whatsappLink = 'https://wa.me/4917661331466';
---

<BaseLayout title={metaTitle} description={metaDescription} canonical={canonical}>

  <!-- Breadcrumb -->
  <div class="bg-warm-gray-50 border-b border-warm-gray-200">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3">
      <nav class="text-sm text-warm-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center gap-1.5">
          <li><a href="/" class="hover:text-green-700 transition-colors">Startseite</a></li>
          <li class="text-warm-gray-300">/</li>
          <li><a href="/leistungen" class="hover:text-green-700 transition-colors">Leistungen</a></li>
          <li class="text-warm-gray-300">/</li>
          <li class="text-warm-gray-700 font-medium">{title}</li>
        </ol>
      </nav>
    </div>
  </div>

  <!-- Hero: 2-Spalten -->
  <section class="bg-warm-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16 lg:py-20">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center">

        <!-- Text -->
        <div>
          {tagline && (
            <div class="inline-flex items-center gap-2 text-sm font-medium text-green-700 bg-green-50 px-3 py-1.5 rounded-full mb-5 border border-green-200">
              <span class="material-symbols-outlined text-[1rem]" aria-hidden="true">location_on</span>
              {tagline}
            </div>
          )}
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-warm-gray-900 leading-tight">{headline}</h1>
          <p class="mt-5 text-base sm:text-lg text-warm-gray-600 leading-relaxed">{intro}</p>

          <div class="mt-8 flex flex-col sm:flex-row gap-3">
            <Button href="/kontakt" variant="primary" size="large">{ctaLabel}</Button>
            <a
              href={whatsappLink}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2.5 bg-[#25D366] text-white font-semibold px-7 py-3.5 rounded-lg hover:bg-[#20ba5a] transition-colors text-base"
              aria-label="Anfrage per WhatsApp senden"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Per WhatsApp anfragen
            </a>
          </div>
        </div>

        <!-- Bild -->
        <div>
          {image ? (
            <img
              src={image}
              alt={imageAlt || headline}
              class="w-full rounded-2xl h-auto shadow-md"
              loading="eager"
            />
          ) : (
            <div class="bg-warm-gray-100 rounded-2xl aspect-video flex items-center justify-center">
              <span class="material-symbols-outlined text-warm-gray-300" style="font-size: 4rem;" aria-hidden="true">image</span>
            </div>
          )}
        </div>

      </div>
    </div>
  </section>

  <!-- Was wir für Sie übernehmen -->
  <section class="bg-warm-gray-50 border-y border-warm-gray-100">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-14">
      <h2 class="text-xl sm:text-2xl font-bold text-warm-gray-900 mb-7">Was wir für Sie übernehmen</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-10 gap-y-3.5">
        {items.map(item => (
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-green-600 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
            </svg>
            <span class="text-warm-gray-700">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sub-Services Karten (optional) -->
  {subServices && subServices.length > 0 && (
    <section class="bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
        <h2 class="text-xl sm:text-2xl font-bold text-warm-gray-900 mb-8">Was wir machen</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
          {subServices.map((s, i) => (
            <div class={`p-6 rounded-xl ${i % 2 === 0 ? 'bg-green-50 border border-green-100' : 'bg-earth-50 border border-earth-100'}`}>
              <span
                class={`material-symbols-outlined text-[2.25rem] mb-4 block ${i % 2 === 0 ? 'text-green-600' : 'text-earth-600'}`}
                aria-hidden="true"
              >{s.icon}</span>
              <h3 class="font-semibold text-warm-gray-900 mb-2">{s.title}</h3>
              <p class="text-sm text-warm-gray-600 leading-relaxed">{s.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Prozess (optional) -->
  {steps && steps.length > 0 && (
    <section class="bg-warm-gray-50 border-y border-warm-gray-100">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
        <h2 class="text-xl sm:text-2xl font-bold text-warm-gray-900 mb-10">So läuft Ihre Anfrage ab</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
          {steps.map((step, i) => (
            <div class="flex gap-4">
              <div class="shrink-0 w-9 h-9 rounded-full bg-green-600 text-white font-bold text-base flex items-center justify-center">
                {i + 1}
              </div>
              <div>
                <h3 class="font-semibold text-warm-gray-900 mb-1">{step.title}</h3>
                <p class="text-sm text-warm-gray-600 leading-relaxed">{step.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Beispiele (optional) -->
  {examples && examples.length > 0 && (
    <section class="bg-white">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
        <div class="flex items-end justify-between mb-8">
          <h2 class="text-xl sm:text-2xl font-bold text-warm-gray-900">Aus unserer Arbeit</h2>
          <a href="/referenzen" class="text-sm font-medium text-green-700 hover:text-green-800 transition-colors inline-flex items-center gap-1">
            Alle Referenzen
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
        <div class:list={['grid grid-cols-1 gap-5', examples.length === 2 ? 'sm:grid-cols-2' : 'sm:grid-cols-3']}>
          {examples.map(ex => (
            <div class="rounded-xl overflow-hidden border border-warm-gray-200">
              <img src={ex.image} alt={ex.alt} class="w-full h-52 object-cover" loading="lazy" />
              <div class="p-4">
                <span class="inline-block text-xs font-medium text-green-700 bg-green-100 px-2.5 py-1 rounded-full mb-2">{ex.label}</span>
                <p class="text-sm text-warm-gray-700 leading-relaxed">{ex.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Custom-Slot für extra Inhalte -->
  <slot />

  <!-- Bottom CTA -->
  <section class="bg-earth-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 sm:py-16 text-center">
      {ctaText && (
        <p class="text-earth-300 text-base max-w-xl mx-auto mb-4">{ctaText}</p>
      )}
      <h2 class="text-2xl sm:text-3xl font-bold text-white leading-tight">
        Bereit für Ihr Projekt?
      </h2>
      <div class="mt-8 flex flex-col sm:flex-row justify-center gap-3 sm:gap-4">
        <Button href="/kontakt" variant="primary" size="large">{ctaLabel}</Button>
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2.5 bg-white/10 text-white font-semibold px-7 py-3.5 rounded-lg hover:bg-white/20 transition-colors border border-white/20 text-base"
          aria-label="Per WhatsApp anfragen"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Per WhatsApp anfragen
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
