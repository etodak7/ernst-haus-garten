---
const navItems = [
  { label: 'Leistungen', href: '/leistungen' },
  { label: 'Über uns', href: '/ueber-uns' },
  { label: 'Referenzen', href: '/referenzen' },
  { label: 'Kontakt', href: '/kontakt' },
];

const whatsappLink = 'https://wa.me/4917661331466';
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-warm-gray-200">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-18 sm:h-22">
      <!-- Logo -->
      <a href="/" class="flex items-center shrink-0" aria-label="ERNST HAUS & GARTEN – Zur Startseite">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 310 100" class="h-14 sm:h-[4.5rem] w-auto" aria-hidden="true" focusable="false">
          <!-- Haus-Icon: nested SVG zeigt nur den Icon-Bereich der Original-Datei -->
          <svg x="0" y="4" width="95" height="92" viewBox="80 40 215 195">
            <defs>
              <clipPath id="ehg-c1"><path d="M 126 101 L 268 101 L 268 220.066406 L 126 220.066406 Z" clip-rule="nonzero"/></clipPath>
              <clipPath id="ehg-c2"><path d="M 108.730469 97 L 245 97 L 245 172 L 108.730469 172 Z" clip-rule="nonzero"/></clipPath>
              <clipPath id="ehg-c3"><path d="M 251 124 L 281.746094 124 L 281.746094 140 L 251 140 Z" clip-rule="nonzero"/></clipPath>
              <clipPath id="ehg-c4"><path d="M 166 47.027344 L 246 47.027344 L 246 127 L 166 127 Z" clip-rule="nonzero"/></clipPath>
              <clipPath id="ehg-c5"><path d="M 111 211 L 262 211 L 262 220.066406 L 111 220.066406 Z" clip-rule="nonzero"/></clipPath>
            </defs>
            <!-- Haus-Umriss (L-Form) -->
            <g clip-path="url(#ehg-c1)">
              <path fill="#685944" d="M 245.894531 220.027344 L 126.910156 220.027344 L 126.910156 151.28125 L 135.378906 151.28125 L 135.378906 211.542969 L 237.425781 211.542969 L 237.425781 124.914062 L 261.113281 101.195312 L 267.085938 107.179688 L 245.894531 128.429688 Z"/>
            </g>
            <!-- Dach-Diagonale -->
            <g clip-path="url(#ehg-c2)">
              <path fill="#685944" d="M 114.242188 171.554688 L 108.707031 165.152344 L 186.414062 97.730469 L 244.464844 148.105469 L 238.910156 154.507812 L 186.414062 108.957031 Z"/>
            </g>
            <!-- Dachspitze -->
            <path fill="#685944" d="M 168.433594 94.1875 L 194.730469 71.371094 L 200.273438 77.789062 L 173.980469 100.601562 Z"/>
            <!-- Grünes Blatt rechts -->
            <path fill="#80c369" d="M 256.300781 89.894531 C 256.429688 98.382812 249.226562 105.382812 249.226562 105.382812 C 249.226562 105.382812 241.824219 98.601562 241.695312 90.113281 C 241.570312 81.625 248.773438 74.628906 248.773438 74.628906 C 248.773438 74.628906 256.175781 81.410156 256.300781 89.894531 Z"/>
            <!-- Grünes Blatt links -->
            <path fill="#80c369" d="M 153.476562 89.097656 C 145.277344 86.957031 140.464844 78.144531 140.464844 78.144531 C 140.464844 78.144531 148.953125 72.796875 157.148438 74.933594 C 165.347656 77.074219 170.160156 85.886719 170.160156 85.886719 C 170.160156 85.886719 161.675781 91.238281 153.476562 89.097656 Z"/>
            <!-- Grünes Blatt unten-rechts -->
            <g clip-path="url(#ehg-c3)">
              <path fill="#80c369" d="M 267.902344 124.929688 C 276.242188 126.402344 281.746094 134.796875 281.746094 134.796875 C 281.746094 134.796875 273.710938 140.816406 265.367188 139.347656 C 257.023438 137.878906 251.523438 129.484375 251.523438 129.484375 C 251.523438 129.484375 259.558594 123.460938 267.902344 124.929688 Z"/>
            </g>
            <!-- Braune Schräge über dem Haus -->
            <g clip-path="url(#ehg-c4)">
              <path fill="#685944" d="M 245.894531 126.671875 L 237.425781 126.671875 L 237.425781 114.832031 L 166.742188 53.480469 L 172.277344 47.0625 L 245.894531 110.949219 Z"/>
            </g>
            <!-- Schornstein -->
            <path fill="#685944" d="M 214.800781 61.625 L 223.210938 60.613281 L 227.511719 96.460938 L 219.105469 97.472656 Z"/>
            <!-- Grüne Fenster (4 Quadrate) -->
            <path fill="#80c369" d="M 173.671875 144.789062 L 184.097656 144.789062 L 184.097656 155.234375 L 173.671875 155.234375 Z"/>
            <path fill="#80c369" d="M 188.710938 144.789062 L 199.132812 144.789062 L 199.132812 155.234375 L 188.710938 155.234375 Z"/>
            <path fill="#80c369" d="M 173.671875 159.859375 L 184.097656 159.859375 L 184.097656 170.304688 L 173.671875 170.304688 Z"/>
            <path fill="#80c369" d="M 188.710938 159.859375 L 199.132812 159.859375 L 199.132812 170.304688 L 188.710938 170.304688 Z"/>
            <!-- Unterer Balken -->
            <g clip-path="url(#ehg-c5)">
              <path fill="#685944" d="M 111.472656 211.542969 L 261.332031 211.542969 L 261.332031 220.027344 L 111.472656 220.027344 Z"/>
            </g>
          </svg>
          <!-- Text neben dem Haus -->
          <text x="104" y="64" font-family="Lexend, sans-serif" font-weight="700" font-size="55" fill="#685944">ERNST</text>
          <text x="106" y="91" font-family="Lexend, sans-serif" font-weight="400" font-size="22" fill="#685944" letter-spacing="0.5">HAUS &amp; GARTEN</text>
        </svg>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-8" aria-label="Hauptnavigation">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium transition-colors hover:text-green-700',
              currentPath.startsWith(item.href)
                ? 'text-green-700'
                : 'text-warm-gray-600'
            ]}
          >
            {item.label}
          </a>
        ))}
        <a
          href={whatsappLink}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-green-600 text-white text-sm font-medium px-4 py-2.5 rounded-lg hover:bg-green-700 transition-colors"
          aria-label="Anfrage per WhatsApp senden"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
      </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 -mr-2 text-warm-gray-600 hover:text-warm-gray-800"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="w-6 h-6" id="menu-icon-open" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="w-6 h-6 hidden" id="menu-icon-close" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden border-t border-warm-gray-200 bg-white">
    <nav class="max-w-6xl mx-auto px-4 py-4 space-y-1" aria-label="Mobile Navigation">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={[
            'block px-3 py-3 rounded-lg text-base font-medium transition-colors',
            currentPath.startsWith(item.href)
              ? 'text-green-700 bg-green-50'
              : 'text-warm-gray-700 hover:bg-warm-gray-50'
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href={whatsappLink}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 px-3 py-3 rounded-lg text-base font-medium text-green-700 hover:bg-green-50 transition-colors"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        WhatsApp-Anfrage
      </a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(isOpen));
    btn.setAttribute('aria-label', isOpen ? 'Menü schließen' : 'Menü öffnen');
    iconOpen?.classList.toggle('hidden', isOpen);
    iconClose?.classList.toggle('hidden', !isOpen);
  });
</script>
