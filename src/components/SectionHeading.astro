---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  tag?: 'h1' | 'h2' | 'h3';
}

const { title, subtitle, align = 'center', tag: Tag = 'h2' } = Astro.props;
---

<div class:list={['mb-10 sm:mb-12', align === 'center' ? 'text-center max-w-2xl mx-auto' : '']}>
  <Tag class="text-2xl sm:text-3xl lg:text-4xl font-bold text-warm-gray-900 leading-tight">{title}</Tag>
  {subtitle && (
    <p class="mt-4 text-base sm:text-lg text-warm-gray-600 leading-relaxed">{subtitle}</p>
  )}
</div>
