---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<a href={href} class="group block bg-white rounded-xl border border-warm-gray-200 p-6 sm:p-8 hover:border-green-300 hover:shadow-md transition-all duration-200">
  <div class="w-12 h-12 rounded-lg bg-green-100 text-green-600 flex items-center justify-center mb-4 group-hover:bg-green-200 transition-colors">
    <Fragment set:html={icon} />
  </div>
  <h3 class="text-lg font-semibold text-warm-gray-900 mb-2 group-hover:text-earth-600 transition-colors">{title}</h3>
  <p class="text-base text-warm-gray-600 leading-relaxed mb-4">{description}</p>
  <span class="inline-flex items-center text-base font-medium text-green-600 group-hover:text-green-700 transition-colors">
    Mehr erfahren
    <svg class="w-4 h-4 ml-1 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </span>
</a>
