---
interface Props {
  title: string;
  description: string;
  href: string;
  materialIcon?: string;
  icon?: string; // legacy SVG HTML fallback
}

const { title, description, href, materialIcon, icon } = Astro.props;
---

<a href={href} class="group block bg-white rounded-xl p-6 sm:p-8 shadow-sm hover:shadow-md transition-all duration-200">
  <div class="mb-5">
    {materialIcon ? (
      <span class="material-symbols-outlined text-green-600" style="font-size: 2.5rem;">{materialIcon}</span>
    ) : (
      <div class="w-12 h-12 rounded-lg bg-green-100 text-green-600 flex items-center justify-center group-hover:bg-green-200 transition-colors">
        <Fragment set:html={icon} />
      </div>
    )}
  </div>
  <h3 class="text-lg font-semibold text-warm-gray-900 mb-2 group-hover:text-green-700 transition-colors">{title}</h3>
  <p class="text-base text-warm-gray-600 leading-relaxed mb-4">{description}</p>
  <span class="inline-flex items-center gap-1 text-base font-medium text-green-600 group-hover:text-green-700 transition-colors">
    Mehr erfahren
    <span class="material-symbols-outlined text-[1.1rem] group-hover:translate-x-0.5 transition-transform" aria-hidden="true">arrow_forward</span>
  </span>
</a>
