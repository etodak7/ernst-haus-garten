# IONOS Webhosting (Apache) - Redirects für deprecated URLs
# Diese Datei wird bei jedem Build mit nach dist/ kopiert und auf IONOS hochgeladen.
# Dort greift sie dann als Apache-Konfiguration.

# -----------------------------------------------------------------------------
# 301 Redirects
# -----------------------------------------------------------------------------

# Die alte Entrümpelungs-Leistungsseite wurde durch die Toplevel-Hub-Seite
# /entruempelung ersetzt. Permanent-Redirect sichert SEO-Juice und verhindert
# Duplicate Content. Vorher hing nur ein Canonical auf der alten Seite - das
# ist jetzt der saubere 301.
Redirect 301 /leistungen/entruempelung-haushaltsaufloesung /entruempelung
Redirect 301 /leistungen/entruempelung-haushaltsaufloesung/ /entruempelung

# -----------------------------------------------------------------------------
# HTTPS erzwingen (falls IONOS das nicht ohnehin schon macht)
# -----------------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# -----------------------------------------------------------------------------
# Standard-Mime-Types für WebP (auf manchen Apache-Setups nötig)
# -----------------------------------------------------------------------------
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/svg+xml .svg
</IfModule>

# -----------------------------------------------------------------------------
# Caching für statische Assets
# -----------------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # Bilder: 1 Jahr Cache (WebP, JPG, PNG, SVG, ICO)
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"

  # Fonts: 1 Jahr
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"

  # CSS & JS: 1 Woche (hash-gebustet durch Astro, könnte auch länger)
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"

  # HTML: keine aggressive Cachung, sonst sieht niemand Updates
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

# -----------------------------------------------------------------------------
# Sicherheits-Header
# -----------------------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>
